package templates

import (
	"strings"

	"secure-ui-showcase-go/internal/assets"
	"secure-ui-showcase-go/internal/i18n"
	"secure-ui-showcase-go/internal/middleware"
	"secure-ui-showcase-go/internal/templates/partials"
)

// pageTitle returns the full <title> string.
// Pages that already lead with "Secure-UI" are returned as-is;
// all others get " — Secure-UI" appended.
func pageTitle(title string) string {
	if len(title) >= 9 && title[:9] == "Secure-UI" {
		return title
	}
	return title + " — Secure-UI"
}

// componentJS maps a component name to its JS module path under /components/.
func componentJS(name string) string {
	return "/components/components/" + name + "/" + name + ".js"
}

// componentModuleHTML builds the <link rel="modulepreload"> and <script type="module">
// tags for per-page component loading. Returns raw HTML safe to pass to templ.Raw().
// Paths are internal constants; nonce is base64 (no HTML special chars).
func componentModuleHTML(nonce string, components []string) string {
	if len(components) == 0 {
		return ""
	}

	var b strings.Builder

	if components[0] == "all" {
		b.WriteString(`<link rel="modulepreload" href="/components/index.js">`)
		b.WriteString(`<script type="module" nonce="`)
		b.WriteString(nonce)
		b.WriteString(`">import '/components/index.js';</script>`)
		return b.String()
	}

	// Targeted per-page loading: preload core deps + specific components.
	b.WriteString(`<link rel="modulepreload" href="/components/core/base-component.js">`)
	b.WriteString(`<link rel="modulepreload" href="/components/core/security-config.js">`)
	for _, c := range components {
		b.WriteString(`<link rel="modulepreload" href="`)
		b.WriteString(componentJS(c))
		b.WriteString(`">`)
	}
	b.WriteString(`<script type="module" nonce="`)
	b.WriteString(nonce)
	b.WriteString(`">`)
	for _, c := range components {
		b.WriteString(`import '`)
		b.WriteString(componentJS(c))
		b.WriteString(`';`)
	}
	b.WriteString(`</script>`)
	return b.String()
}

// Layout is the standard site layout with navbar and footer.
//
// pageCSS:    per-page stylesheet paths (nil = none beyond global).
// components: component names to load ("all" loads the full barrel;
//
//	empty = no components; specific names = targeted imports).
templ Layout(title string, description string, prism bool, pageCSS []string, components ...string) {
	<!DOCTYPE html>
	<html lang={ string(i18n.LocaleFromContext(ctx)) }>
		@Head(title, description, prism, pageCSS, components)
		<body>
			@partials.Navbar(middleware.UserFromContext(ctx) != nil)
			<div class="main-content">
				<main>
					{ children... }
				</main>
				@partials.Footer()
			</div>
		</body>
	</html>
}

// LandingLayout is a full-bleed layout for standalone landing pages.
// No navbar or footer — the page owns the entire viewport.
templ LandingLayout(title string, description string) {
	<!DOCTYPE html>
	<html lang={ string(i18n.LocaleFromContext(ctx)) }>
		@LandingHead(title, description)
		<body>
			<main>
				{ children... }
			</main>
		</body>
	</html>
}

templ Head(title string, description string, prism bool, pageCSS []string, components []string) {
	<head>
		<meta charset="UTF-8"/>
		<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
		<meta name="robots" content="index, follow"/>
		<meta name="theme-color" content="#0d0e14"/>
		<title>{ pageTitle(title) }</title>
		if description != "" {
			<meta name="description" content={ description }/>
		}
		<!-- Canonical URL -->
		if canonicalURL := middleware.CanonicalURLFromContext(ctx); canonicalURL != "" {
			<link rel="canonical" href={ canonicalURL }/>
		}
		<!-- LLMs.txt -->
		<link rel="alternate" type="text/plain" href="/llms.txt" title="LLMs.txt"/>
		<!-- Open Graph -->
		<meta property="og:site_name" content="Secure-UI"/>
		<meta property="og:type" content="website"/>
		<meta property="og:title" content={ pageTitle(title) }/>
		if description != "" {
			<meta property="og:description" content={ description }/>
		}
		if canonicalURL := middleware.CanonicalURLFromContext(ctx); canonicalURL != "" {
			<meta property="og:url" content={ canonicalURL }/>
		}
		if siteURL := middleware.SiteBaseURLFromContext(ctx); siteURL != "" {
			<meta property="og:image" content={ siteURL + "/static/og-image.png" }/>
			<meta property="og:image:width" content="1200"/>
			<meta property="og:image:height" content="630"/>
			<meta property="og:image:type" content="image/png"/>
			<meta property="og:image:alt" content="Secure-UI — Security-hardened Web Components"/>
		}
		<!-- Twitter Card -->
		<meta name="twitter:card" content="summary_large_image"/>
		<meta name="twitter:title" content={ pageTitle(title) }/>
		if description != "" {
			<meta name="twitter:description" content={ description }/>
		}
		if siteURL := middleware.SiteBaseURLFromContext(ctx); siteURL != "" {
			<meta name="twitter:image" content={ siteURL + "/static/og-image.png" }/>
			<meta name="twitter:image:alt" content="Secure-UI — Security-hardened Web Components"/>
		}
		<!-- Self-hosted fonts: preload WOFF2 files before CSS is parsed -->
		<link rel="preload" href="/static/fonts/ibm-plex-sans.woff2" as="font" type="font/woff2" crossorigin/>
		<link rel="preload" href="/static/fonts/manrope.woff2" as="font" type="font/woff2" crossorigin/>
		<link rel="preload" href="/static/fonts/ibm-plex-mono-400.woff2" as="font" type="font/woff2" crossorigin/>
		<!-- Favicon -->
		<link rel="icon" type="image/x-icon" href="/static/favicon.ico"/>
		<link rel="icon" type="image/svg+xml" href="/static/favicon.svg"/>
		<link rel="icon" type="image/png" sizes="32x32" href="/static/favicon-32x32.png"/>
		<link rel="icon" type="image/png" sizes="16x16" href="/static/favicon-16x16.png"/>
		<link rel="apple-touch-icon" sizes="180x180" href="/static/favicon-32x32.png"/>
		<!-- Global CSS (tokens + fonts + base + nav + footer + view-transitions) -->
		<link rel="stylesheet" href={ assets.URL("/static/styles/global/global.min.css") }/>
		<!-- Page-specific CSS -->
		for _, css := range pageCSS {
			<link rel="stylesheet" href={ assets.URL(css) }/>
		}
		<!-- View Transitions — inlined to avoid extra HTTP request -->
		<script nonce={ middleware.NonceFromContext(ctx) }>(function(){var n={"/":0,"/forms":1,"/documentation":2,"/login":3,"/register":3,"/registration":3,"/dashboard":4,"/table":5,"/profile":6};function r(i){try{var a=new URL(i).pathname.replace(/\/$/,"")||"/";return a.startsWith("/documentation/")?2:n[a]!==void 0?n[a]:-1}catch{return-1}}window.addEventListener("unhandledrejection",function(e){if(e.reason&&e.reason.name==="AbortError")e.preventDefault();});window.addEventListener("pagereveal",function(i){if(i.viewTransition&&navigation.activation){var a=r(navigation.activation.from.url),t=r(navigation.activation.entry.url);a>=0&&t>=0&&a!==t&&(t>a?i.viewTransition.types.add("forwards"):i.viewTransition.types.add("backwards"))}})})();</script>
		<!-- Web Components: load only what this page uses -->
		@templ.Raw(componentModuleHTML(middleware.NonceFromContext(ctx), components))
		<!-- Prism: lazy-loaded when a code block scrolls into view -->
		if prism {
			<script defer src={ assets.URL("/static/js/prism-loader.min.js") } nonce={ middleware.NonceFromContext(ctx) }></script>
		}
	</head>
}

// LandingHead is a minimal <head> for standalone landing pages.
templ LandingHead(title string, description string) {
	<head>
		<meta charset="UTF-8"/>
		<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
		<meta name="robots" content="index, follow"/>
		<meta name="theme-color" content="#0d0e14"/>
		<title>{ pageTitle(title) }</title>
		if description != "" {
			<meta name="description" content={ description }/>
		}
		<!-- Canonical URL -->
		if canonicalURL := middleware.CanonicalURLFromContext(ctx); canonicalURL != "" {
			<link rel="canonical" href={ canonicalURL }/>
		}
		<!-- LLMs.txt -->
		<link rel="alternate" type="text/plain" href="/llms.txt" title="LLMs.txt"/>
		<!-- Open Graph -->
		<meta property="og:site_name" content="Secure-UI"/>
		<meta property="og:type" content="website"/>
		<meta property="og:title" content={ pageTitle(title) }/>
		if description != "" {
			<meta property="og:description" content={ description }/>
		}
		if canonicalURL := middleware.CanonicalURLFromContext(ctx); canonicalURL != "" {
			<meta property="og:url" content={ canonicalURL }/>
		}
		if siteURL := middleware.SiteBaseURLFromContext(ctx); siteURL != "" {
			<meta property="og:image" content={ siteURL + "/static/og-image.png" }/>
			<meta property="og:image:width" content="1200"/>
			<meta property="og:image:height" content="630"/>
			<meta property="og:image:type" content="image/png"/>
			<meta property="og:image:alt" content="Secure-UI — Security-hardened Web Components"/>
		}
		<!-- Twitter Card -->
		<meta name="twitter:card" content="summary_large_image"/>
		<meta name="twitter:title" content={ pageTitle(title) }/>
		if description != "" {
			<meta name="twitter:description" content={ description }/>
		}
		if siteURL := middleware.SiteBaseURLFromContext(ctx); siteURL != "" {
			<meta name="twitter:image" content={ siteURL + "/static/og-image.png" }/>
			<meta name="twitter:image:alt" content="Secure-UI — Security-hardened Web Components"/>
		}
		<!-- Self-hosted fonts -->
		<link rel="preload" href="/static/fonts/ibm-plex-sans.woff2" as="font" type="font/woff2" crossorigin/>
		<link rel="preload" href="/static/fonts/manrope.woff2" as="font" type="font/woff2" crossorigin/>
		<!-- Favicon -->
		<link rel="icon" type="image/x-icon" href="/static/favicon.ico"/>
		<link rel="icon" type="image/svg+xml" href="/static/favicon.svg"/>
		<link rel="icon" type="image/png" sizes="32x32" href="/static/favicon-32x32.png"/>
		<link rel="apple-touch-icon" sizes="180x180" href="/static/favicon-32x32.png"/>
		<!-- Landing page CSS only -->
		<link rel="stylesheet" href={ assets.URL("/static/styles/fonts/fonts.min.css") }/>
		<link rel="stylesheet" href={ assets.URL("/static/styles/tokens/tokens.min.css") }/>
		<link rel="stylesheet" href={ assets.URL("/static/styles/base/base.min.css") }/>
		<link rel="stylesheet" href={ assets.URL("/static/styles/telemetry-pro/telemetry-pro.min.css") }/>
	</head>
}
