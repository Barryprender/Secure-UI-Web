package templates

import (
	"secure-ui-showcase-go/internal/assets"
	"secure-ui-showcase-go/internal/i18n"
	"secure-ui-showcase-go/internal/middleware"
	"secure-ui-showcase-go/internal/templates/partials"
)

// pageTitle returns the full <title> string.
// Pages that already lead with "Secure-UI" are returned as-is;
// all others get " — Secure-UI" appended.
func pageTitle(title string) string {
	if len(title) >= 9 && title[:9] == "Secure-UI" {
		return title
	}
	return title + " — Secure-UI"
}

templ Layout(title string, description string, prism bool, pageCSS ...string) {
	<!DOCTYPE html>
	<html lang={ string(i18n.LocaleFromContext(ctx)) }>
		@Head(title, description, prism, pageCSS)
		<body>
			@partials.Navbar(middleware.UserFromContext(ctx) != nil)
			<div class="main-content">
				<main>
					{ children... }
				</main>
				@partials.Footer()
			</div>
		</body>
	</html>
}

// LandingLayout is a full-bleed layout for standalone landing pages.
// No navbar or footer — the page owns the entire viewport.
templ LandingLayout(title string, description string) {
	<!DOCTYPE html>
	<html lang={ string(i18n.LocaleFromContext(ctx)) }>
		@LandingHead(title, description)
		<body>
			<main>
				{ children... }
			</main>
		</body>
	</html>
}

templ Head(title string, description string, prism bool, pageCSS []string) {
	<head>
		<meta charset="UTF-8"/>
		<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
		<meta name="robots" content="index, follow"/>
		<title>{ pageTitle(title) }</title>
		if description != "" {
			<meta name="description" content={ description }/>
		}
		<!-- Canonical URL -->
		if canonicalURL := middleware.CanonicalURLFromContext(ctx); canonicalURL != "" {
			<link rel="canonical" href={ canonicalURL }/>
		}
		<!-- LLMs.txt — machine-readable site summary for AI agents -->
		<link rel="alternate" type="text/plain" href="/llms.txt" title="LLMs.txt"/>
		<!-- Open Graph -->
		<meta property="og:site_name" content="Secure-UI"/>
		<meta property="og:type" content="website"/>
		<meta property="og:title" content={ pageTitle(title) }/>
		if description != "" {
			<meta property="og:description" content={ description }/>
		}
		if canonicalURL := middleware.CanonicalURLFromContext(ctx); canonicalURL != "" {
			<meta property="og:url" content={ canonicalURL }/>
		}
		if siteURL := middleware.SiteBaseURLFromContext(ctx); siteURL != "" {
			<meta property="og:image" content={ siteURL + "/static/og-image.png" }/>
			<meta property="og:image:width" content="1200"/>
			<meta property="og:image:height" content="630"/>
			<meta property="og:image:type" content="image/png"/>
		}
		<!-- Twitter Card -->
		<meta name="twitter:card" content="summary_large_image"/>
		<meta name="twitter:title" content={ pageTitle(title) }/>
		if description != "" {
			<meta name="twitter:description" content={ description }/>
		}
		if siteURL := middleware.SiteBaseURLFromContext(ctx); siteURL != "" {
			<meta name="twitter:image" content={ siteURL + "/static/og-image.png" }/>
		}
		<!-- Fonts: non-render-blocking — preload then apply via script -->
		<link rel="preconnect" href="https://fonts.googleapis.com"/>
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous"/>
		<link rel="preload" as="style" id="gfonts" href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;600&family=IBM+Plex+Sans:wght@400;500;600;700&family=Manrope:wght@600;700;800&display=swap"/>
		<noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;600&family=IBM+Plex+Sans:wght@400;500;600;700&family=Manrope:wght@600;700;800&display=swap"/></noscript>
		<script nonce={ middleware.NonceFromContext(ctx) }>(function(){var l=document.getElementById('gfonts');l.onload=function(){l.rel='stylesheet';};})();</script>
		<!-- Favicon - multiple formats for maximum compatibility -->
		<link rel="icon" type="image/x-icon" href="/static/favicon.ico"/>
		<link rel="icon" type="image/svg+xml" href="/static/favicon.svg"/>
		<link rel="icon" type="image/png" sizes="32x32" href="/static/favicon-32x32.png"/>
		<link rel="icon" type="image/png" sizes="16x16" href="/static/favicon-16x16.png"/>
		<link rel="apple-touch-icon" sizes="180x180" href="/static/apple-touch-icon.png"/>

		<!-- Global CSS — tokens, base, nav, footer, view-transitions, no-js (combined, 1 request) -->
		<link rel="preload" as="style" href={ assets.URL("/static/styles/global/global.min.css") }/>
		<link rel="stylesheet" href={ assets.URL("/static/styles/global/global.min.css") }/>

		<!-- Page-specific CSS — preloaded in parallel with global -->
		for _, css := range pageCSS {
			<link rel="preload" as="style" href={ assets.URL(css) }/>
			<link rel="stylesheet" href={ assets.URL(css) }/>
		}
		if prism {
			<!-- Prism CSS loaded async — code blocks are below fold, does not affect LCP -->
			<script nonce={ middleware.NonceFromContext(ctx) }>(function(){var l=document.createElement('link');l.rel='stylesheet';l.href='/static/styles/prism/prism.min.css';document.head.appendChild(l);})()</script>
		}

		<!-- View Transitions — inlined to avoid extra HTTP request -->
		<script nonce={ middleware.NonceFromContext(ctx) }>(function(){var n={"/":0,"/forms":1,"/documentation":2,"/login":3,"/register":3,"/registration":3,"/dashboard":4,"/table":5,"/profile":6};function r(i){try{var a=new URL(i).pathname.replace(/\/$/,"")||"/";return a.startsWith("/documentation/")?2:n[a]!==void 0?n[a]:-1}catch{return-1}}window.addEventListener("unhandledrejection",function(e){if(e.reason&&e.reason.name==="AbortError")e.preventDefault();});window.addEventListener("pagereveal",function(i){if(i.viewTransition&&navigation.activation){var a=r(navigation.activation.from.url),t=r(navigation.activation.entry.url);a>=0&&t>=0&&a!==t&&(t>a?i.viewTransition.types.add("forwards"):i.viewTransition.types.add("backwards"))}})})();</script>

		<!-- Secure-UI Components - modulepreload for earlier fetch, then self-register -->
		<link rel="modulepreload" href="/components/index.js" nonce={ middleware.NonceFromContext(ctx) }/>
		<script type="module" nonce={ middleware.NonceFromContext(ctx) }>
			import '/components/index.js';
		</script>
		if prism {
			<script defer src={ assets.URL("/static/js/prism.min.js") }></script>
			<script defer src={ assets.URL("/static/js/prism-go.min.js") }></script>
			<script defer src={ assets.URL("/static/js/prism-javascript.min.js") }></script>
			<script defer src={ assets.URL("/static/js/prism-typescript.min.js") }></script>
			<script defer src={ assets.URL("/static/js/prism-bash.min.js") }></script>
			<script defer src={ assets.URL("/static/js/prism-json.min.js") }></script>
			<script defer src={ assets.URL("/static/js/prism-markup.min.js") }></script>
			<script defer src={ assets.URL("/static/js/prism-css.min.js") }></script>
		}
	</head>
}

// LandingHead is a minimal <head> for standalone landing pages.
// Loads only the fonts and CSS the landing page requires —
// no site navigation, forms, documentation, or Prism stylesheets.
templ LandingHead(title string, description string) {
	<head>
		<meta charset="UTF-8"/>
		<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
		<meta name="robots" content="index, follow"/>
		<title>{ pageTitle(title) }</title>
		if description != "" {
			<meta name="description" content={ description }/>
		}
		<!-- Canonical URL -->
		if canonicalURL := middleware.CanonicalURLFromContext(ctx); canonicalURL != "" {
			<link rel="canonical" href={ canonicalURL }/>
		}
		<!-- LLMs.txt — machine-readable site summary for AI agents -->
		<link rel="alternate" type="text/plain" href="/llms.txt" title="LLMs.txt"/>
		<!-- Open Graph — landing page specific -->
		<meta property="og:site_name" content="Secure-UI"/>
		<meta property="og:type" content="website"/>
		<meta property="og:title" content={ pageTitle(title) }/>
		if description != "" {
			<meta property="og:description" content={ description }/>
		}
		if canonicalURL := middleware.CanonicalURLFromContext(ctx); canonicalURL != "" {
			<meta property="og:url" content={ canonicalURL }/>
		}
		if siteURL := middleware.SiteBaseURLFromContext(ctx); siteURL != "" {
			<meta property="og:image" content={ siteURL + "/static/og-telemetry.png" }/>
			<meta property="og:image:width" content="1200"/>
			<meta property="og:image:height" content="630"/>
			<meta property="og:image:type" content="image/png"/>
		}
		<!-- Twitter Card -->
		<meta name="twitter:card" content="summary_large_image"/>
		<meta name="twitter:title" content={ pageTitle(title) }/>
		if description != "" {
			<meta name="twitter:description" content={ description }/>
		}
		if siteURL := middleware.SiteBaseURLFromContext(ctx); siteURL != "" {
			<meta name="twitter:image" content={ siteURL + "/static/og-telemetry.png" }/>
		}
		<!-- Fonts: non-render-blocking -->
		<link rel="preconnect" href="https://fonts.googleapis.com"/>
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous"/>
		<link rel="preload" as="style" id="gfonts" href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;600&family=IBM+Plex+Sans:wght@400;500;600;700&family=Manrope:wght@600;700;800&display=swap"/>
		<noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;600&family=IBM+Plex+Sans:wght@400;500;600;700&family=Manrope:wght@600;700;800&display=swap"/></noscript>
		<script nonce={ middleware.NonceFromContext(ctx) }>(function(){var l=document.getElementById('gfonts');l.onload=function(){l.rel='stylesheet';};})();</script>
		<!-- Favicon -->
		<link rel="icon" type="image/x-icon" href="/static/favicon.ico"/>
		<link rel="icon" type="image/svg+xml" href="/static/favicon.svg"/>
		<link rel="icon" type="image/png" sizes="32x32" href="/static/favicon-32x32.png"/>
		<link rel="apple-touch-icon" sizes="180x180" href="/static/apple-touch-icon.png"/>

		<!-- Landing page CSS only -->
		<link rel="preload" as="style" href={ assets.URL("/static/styles/tokens/tokens.min.css") }/>
		<link rel="preload" as="style" href={ assets.URL("/static/styles/base/base.min.css") }/>
		<link rel="preload" as="style" href={ assets.URL("/static/styles/telemetry-pro/telemetry-pro.min.css") }/>
		<link rel="stylesheet" href={ assets.URL("/static/styles/tokens/tokens.min.css") }/>
		<link rel="stylesheet" href={ assets.URL("/static/styles/base/base.min.css") }/>
		<link rel="stylesheet" href={ assets.URL("/static/styles/telemetry-pro/telemetry-pro.min.css") }/>
	</head>
}
