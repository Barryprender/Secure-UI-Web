package templates

import (
	"secure-ui-showcase-go/internal/i18n"
	"secure-ui-showcase-go/internal/middleware"
	"secure-ui-showcase-go/internal/templates/partials"
)

templ Layout(title string, description string, prism bool, pageCSS ...string) {
	<!DOCTYPE html>
	<html lang={ string(i18n.LocaleFromContext(ctx)) }>
		@Head(title, description, pageCSS)
		<body>
			@partials.Navbar(middleware.UserFromContext(ctx) != nil)
			<div class="main-content">
				<main>
					{ children... }
				</main>
				@partials.Footer()
			</div>
			if prism {
				<!-- Prism.js syntax highlighting -->
				<script defer src="/static/js/prism.js"></script>
				<script defer src="/static/js/prism-go.min.js"></script>
				<script defer src="/static/js/prism-javascript.min.js"></script>
				<script defer src="/static/js/prism-typescript.min.js"></script>
				<script defer src="/static/js/prism-bash.min.js"></script>
				<script defer src="/static/js/prism-json.min.js"></script>
				<script defer src="/static/js/prism-markup.min.js"></script>
				<script defer src="/static/js/prism-css.min.js"></script>
			}
		</body>
	</html>
}

// LandingLayout is a full-bleed layout for standalone landing pages.
// No navbar or footer — the page owns the entire viewport.
templ LandingLayout(title string, description string) {
	<!DOCTYPE html>
	<html lang={ string(i18n.LocaleFromContext(ctx)) }>
		@LandingHead(title, description)
		<body>
			<main>
				{ children... }
			</main>
		</body>
	</html>
}

templ Head(title string, description string, pageCSS []string) {
	<head>
		<meta charset="UTF-8"/>
		<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
		<meta name="robots" content="index, follow"/>
		<title>{ title } - Secure-UI</title>
		if description != "" {
			<meta name="description" content={ description }/>
		}
		<!-- Canonical URL -->
		if canonicalURL := middleware.CanonicalURLFromContext(ctx); canonicalURL != "" {
			<link rel="canonical" href={ canonicalURL }/>
		}
		<!-- LLMs.txt — machine-readable site summary for AI agents -->
		<link rel="alternate" type="text/plain" href="/llms.txt" title="LLMs.txt"/>
		<!-- Open Graph -->
		<meta property="og:site_name" content="Secure-UI"/>
		<meta property="og:type" content="website"/>
		<meta property="og:title" content={ title + " - Secure-UI" }/>
		if description != "" {
			<meta property="og:description" content={ description }/>
		}
		if canonicalURL := middleware.CanonicalURLFromContext(ctx); canonicalURL != "" {
			<meta property="og:url" content={ canonicalURL }/>
		}
		if siteURL := middleware.SiteBaseURLFromContext(ctx); siteURL != "" {
			<meta property="og:image" content={ siteURL + "/static/og-image.png" }/>
			<meta property="og:image:width" content="1200"/>
			<meta property="og:image:height" content="630"/>
			<meta property="og:image:type" content="image/png"/>
		}
		<!-- Twitter Card -->
		<meta name="twitter:card" content="summary_large_image"/>
		<meta name="twitter:title" content={ title + " - Secure-UI" }/>
		if description != "" {
			<meta name="twitter:description" content={ description }/>
		}
		if siteURL := middleware.SiteBaseURLFromContext(ctx); siteURL != "" {
			<meta name="twitter:image" content={ siteURL + "/static/og-image.png" }/>
		}
		<!-- Fonts: Manrope (display) + IBM Plex Sans (body) + IBM Plex Mono (code) -->
		<link rel="preconnect" href="https://fonts.googleapis.com"/>
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous"/>
		<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;600&family=IBM+Plex+Sans:wght@400;500;600;700&family=Manrope:wght@600;700;800&display=swap"/>
		<!-- Favicon - multiple formats for maximum compatibility -->
		<link rel="icon" type="image/x-icon" href="/static/favicon.ico"/>
		<link rel="icon" type="image/svg+xml" href="/static/favicon.svg"/>
		<link rel="icon" type="image/png" sizes="32x32" href="/static/favicon-32x32.png"/>
		<link rel="icon" type="image/png" sizes="16x16" href="/static/favicon-16x16.png"/>
		<link rel="apple-touch-icon" sizes="180x180" href="/static/apple-touch-icon.png"/>

		<!-- Global CSS -->
		<link rel="stylesheet" href="/static/styles/tokens.css"/>
		<link rel="stylesheet" href="/static/styles/base.css"/>
		<link rel="stylesheet" href="/static/styles/navigation.css"/>
		<link rel="stylesheet" href="/static/styles/footer.css"/>
		<link rel="stylesheet" href="/static/styles/view-transitions.css"/>
		<link rel="stylesheet" href="/static/styles/no-js-fallback.css"/>

		<!-- Page-specific CSS -->
		for _, css := range pageCSS {
			<link rel="stylesheet" href={ css }/>
		}

		<!-- View Transitions — directional navigation (parser-blocking, must run before first render) -->
		<script nonce={ middleware.NonceFromContext(ctx) } src="/static/js/view-transitions.js"></script>

		<!-- Secure-UI Components - modulepreload for earlier fetch, then self-register -->
		<link rel="modulepreload" href="/components/index.js" nonce={ middleware.NonceFromContext(ctx) }/>
		<script type="module" nonce={ middleware.NonceFromContext(ctx) }>
			import '/components/index.js';
		</script>
	</head>
}

// LandingHead is a minimal <head> for standalone landing pages.
// Loads only the fonts and CSS the landing page requires —
// no site navigation, forms, documentation, or Prism stylesheets.
templ LandingHead(title string, description string) {
	<head>
		<meta charset="UTF-8"/>
		<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
		<meta name="robots" content="index, follow"/>
		<title>{ title } - Secure-UI</title>
		if description != "" {
			<meta name="description" content={ description }/>
		}
		<!-- Canonical URL -->
		if canonicalURL := middleware.CanonicalURLFromContext(ctx); canonicalURL != "" {
			<link rel="canonical" href={ canonicalURL }/>
		}
		<!-- LLMs.txt — machine-readable site summary for AI agents -->
		<link rel="alternate" type="text/plain" href="/llms.txt" title="LLMs.txt"/>
		<!-- Open Graph — landing page specific -->
		<meta property="og:site_name" content="Secure-UI"/>
		<meta property="og:type" content="website"/>
		<meta property="og:title" content={ title + " - Secure-UI" }/>
		if description != "" {
			<meta property="og:description" content={ description }/>
		}
		if canonicalURL := middleware.CanonicalURLFromContext(ctx); canonicalURL != "" {
			<meta property="og:url" content={ canonicalURL }/>
		}
		if siteURL := middleware.SiteBaseURLFromContext(ctx); siteURL != "" {
			<meta property="og:image" content={ siteURL + "/static/og-telemetry.png" }/>
			<meta property="og:image:width" content="1200"/>
			<meta property="og:image:height" content="630"/>
			<meta property="og:image:type" content="image/png"/>
		}
		<!-- Twitter Card -->
		<meta name="twitter:card" content="summary_large_image"/>
		<meta name="twitter:title" content={ title + " - Secure-UI" }/>
		if description != "" {
			<meta name="twitter:description" content={ description }/>
		}
		if siteURL := middleware.SiteBaseURLFromContext(ctx); siteURL != "" {
			<meta name="twitter:image" content={ siteURL + "/static/og-telemetry.png" }/>
		}
		<!-- Fonts: Manrope (display) + IBM Plex Sans (body) + IBM Plex Mono (code) -->
		<link rel="preconnect" href="https://fonts.googleapis.com"/>
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous"/>
		<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;600&family=IBM+Plex+Sans:wght@400;500;600;700&family=Manrope:wght@600;700;800&display=swap"/>
		<!-- Favicon -->
		<link rel="icon" type="image/x-icon" href="/static/favicon.ico"/>
		<link rel="icon" type="image/svg+xml" href="/static/favicon.svg"/>
		<link rel="icon" type="image/png" sizes="32x32" href="/static/favicon-32x32.png"/>
		<link rel="apple-touch-icon" sizes="180x180" href="/static/apple-touch-icon.png"/>

		<!-- Landing page CSS only -->
		<link rel="stylesheet" href="/static/styles/tokens.css"/>
		<link rel="stylesheet" href="/static/styles/base.css"/>
		<link rel="stylesheet" href="/static/styles/telemetry-pro.css"/>
	</head>
}
