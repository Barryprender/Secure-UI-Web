						<tr>
							<td><code>name</code></td>
							<td>string</td>
							<td>-</td>
							<td>Form field name for submission</td>
						</tr>
						<tr>
							<td><code>label</code></td>
							<td>string</td>
							<td>-</td>
							<td>Accessible label text</td>
						</tr>
						<tr>
							<td><code>placeholder</code></td>
							<td>string</td>
							<td>-</td>
							<td>Placeholder text</td>
						</tr>
						<tr>
							<td><code>required</code></td>
