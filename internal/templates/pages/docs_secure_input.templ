						<tr>
							<td><code>max</code></td>
							<td>number</td>
							<td>-</td>
							<td>Maximum value (for number type)</td>
						</tr>
						<tr>
							<td><code>pattern</code></td>
							<td>string</td>
							<td>-</td>
							<td>Regex pattern for validation</td>
						</tr>
						<tr>
							<td><code>threat-feedback</code></td>
							<td>boolean</td>
							<td><code>false</code></td>
							<td>Show inline amber warning when an injection pattern is detected. Opt-in — omit on fields where injection syntax is legitimate input (e.g. code editors).</td>
						</tr>
					</tbody>
				</table>

				<h3 class="docs-section-subtitle">Properties</h3>
				<div class="docs-property-list">
					<div class="docs-property">
						<span class="docs-property-name">value</span>
