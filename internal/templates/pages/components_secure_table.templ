					<div class="framework-tab-panel">
						<div class="framework-tab-header">
							<span class="framework-tab-name">React (JSX)</span>
							<span class="framework-tab-lang">tsx</span>
						</div>
						<pre><code class="language-jsx">{ `import { useEffect, useRef } from 'react';

const COLUMNS = [
  { key: 'name',  label: 'Name',  sortable: true, filterable: true },
  { key: 'email', label: 'Email', sortable: true },
  { key: 'role',  label: 'Role',  sortable: true },
];

export function UserTable({ users }) {
  const ref = useRef(null);

  useEffect(() => {
    import('/components/secure-table/secure-table.js').then(() => {
      if (ref.current) {
        ref.current.columns = COLUMNS;
        ref.current.data = users;
      }
    });
  }, [users]);

  return (
    <secure-table
      ref={ref}
      security-tier="authenticated"
      sortable
      filterable
    />
  );
}` }</code></pre>
					</div>

					<div class="framework-tab-panel">
						<div class="framework-tab-header">
							<span class="framework-tab-name">Vue 3</span>
							<span class="framework-tab-lang">vue</span>
						</div>
						<pre><code class="language-markup">{ `<template>
  <secure-table
    ref="tableEl"
    security-tier="authenticated"
    sortable
    filterable>
  </secure-table>
</template>

<script setup>
import { ref, onMounted, watch } from 'vue';

const props = defineProps({ rows: Array });
const tableEl = ref(null);

const columns = [
  { key: 'name',  label: 'Name',  sortable: true, filterable: true },
  { key: 'email', label: 'Email', sortable: true },
  { key: 'role',  label: 'Role',  sortable: true },
];

onMounted(async () => {
  await import('/components/secure-table/secure-table.js');
  tableEl.value.columns = columns;
  tableEl.value.data = props.rows;
});

watch(() => props.rows, (rows) => {
  if (tableEl.value) tableEl.value.data = rows;
});
</script>` }</code></pre>
					</div>

					<div class="framework-tab-panel">
						<div class="framework-tab-header">
							<span class="framework-tab-name">Angular</span>
							<span class="framework-tab-lang">typescript</span>
						</div>
						<pre><code class="language-typescript">{ "import {\n  Component, Input, AfterViewInit,\n  ElementRef, ViewChild,\n  CUSTOM_ELEMENTS_SCHEMA\n} from '@angular/core';\n\n@Component({\n  selector: 'app-user-table',\n  template: `\n    <secure-table\n      #tableEl\n      security-tier=\"authenticated\"\n      sortable filterable>\n    </secure-table>\n  `,\n  schemas: [CUSTOM_ELEMENTS_SCHEMA],\n})\nexport class UserTableComponent implements AfterViewInit {\n  @Input() rows: Record<string, unknown>[] = [];\n  @ViewChild('tableEl') tableEl!: ElementRef;\n\n  private columns = [\n    { key: 'name',  label: 'Name',  sortable: true, filterable: true },\n    { key: 'email', label: 'Email', sortable: true },\n    { key: 'role',  label: 'Role',  sortable: true },\n  ];\n\n  async ngAfterViewInit() {\n    await import('/components/secure-table/secure-table.js');\n    this.tableEl.nativeElement.columns = this.columns;\n    this.tableEl.nativeElement.data    = this.rows;\n  }\n}" }</code></pre>
					</div>

					<div class="framework-tab-panel">
						<div class="framework-tab-header">
							<span class="framework-tab-name">Svelte</span>
							<span class="framework-tab-lang">svelte</span>
						</div>
						<pre><code class="language-markup">{ `<script>
  import { onMount } from 'svelte';
  export let rows = [];

  let tableEl;
  const columns = [
    { key: 'name',  label: 'Name',  sortable: true, filterable: true },
    { key: 'email', label: 'Email', sortable: true },
    { key: 'role',  label: 'Role',  sortable: true },
  ];

  onMount(async () => {
    await import('/components/secure-table/secure-table.js');
    tableEl.columns = columns;
    tableEl.data    = rows;
  });

  $: if (tableEl) tableEl.data = rows;
</script>

<secure-table
  bind:this={tableEl}
  security-tier="authenticated"
  sortable filterable>
</secure-table>` }</code></pre>
					</div>

					<div class="framework-tab-panel">
						<div class="framework-tab-header">
							<span class="framework-tab-name">Go / Templ — slotted</span>
							<span class="framework-tab-lang">templ</span>
						</div>
						<pre><code class="language-markup">{ `// Pass rows from your handler — no JS required.
// The component reads the slotted <table> on mount.
templ UserTable(users []User) {
  <secure-table security-tier="authenticated" sortable filterable>
    <table slot="table">
      <thead>
        <tr>
          <th data-key="name"  data-sortable="true">Name</th>
          <th data-key="email" data-sortable="true">Email</th>
          <th data-key="role"  data-sortable="true">Role</th>
        </tr>
      </thead>
      <tbody>
        for _, u := range users {
          <tr>
            <td>{ u.Name }</td>
            <td>{ u.Email }</td>
            <td>{ u.Role }</td>
          </tr>
        }
      </tbody>
    </table>
  </secure-table>
}` }</code></pre>
					</div>

				</div>
