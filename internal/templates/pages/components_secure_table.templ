// The component reads the slotted <table> on mount.
templ UserTable(users []User) {
  <secure-table security-tier="authenticated" sortable filterable>
    <table slot="table">
      <thead>
        <tr>
          <th data-key="name"  data-sortable="true">Name</th>
          <th data-key="email" data-sortable="true">Email</th>
          <th data-key="role"  data-sortable="true">Role</th>
        </tr>
      </thead>
      <tbody>
        for _, u := range users {
          <tr>
            <td>{ u.Name }</td>
            <td>{ u.Email }</td>
            <td>{ u.Role }</td>
          </tr>
        }
      </tbody>
    </table>
  </secure-table>
}` }</code></pre>
