  <secure-table
    ref="tableEl"
    security-tier="authenticated"
    sortable
    filterable>
  </secure-table>
</template>

<script setup>
import { ref, onMounted, watch } from 'vue';

const props = defineProps({ rows: Array });
const tableEl = ref(null);

const columns = [
  { key: 'name',  label: 'Name',  sortable: true, filterable: true },
  { key: 'email', label: 'Email', sortable: true },
  { key: 'role',  label: 'Role',  sortable: true },
];

onMounted(async () => {
  await import('/components/secure-table/secure-table.js');
  tableEl.value.columns = columns;
  tableEl.value.data = props.rows;
});

watch(() => props.rows, (rows) => {
  if (tableEl.value) tableEl.value.data = rows;
});
</script>` }</code></pre>
