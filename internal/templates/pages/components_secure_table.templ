package pages

import (
	"secure-ui-showcase-go/internal/middleware"
	"secure-ui-showcase-go/internal/templates"
)

templ ComponentSecureTable() {
	@templates.Layout("Live Demo: Secure Table — Sorting, Filtering, Security Tiers", "Interactive demos for secure-table: server-rendered slotted content, sorting, filtering, pagination, column security tiers, and framework examples.", true, "/static/styles/components.min.css") {
		@templates.ComponentPageJsonLDScript("secure-table", "Secure data table with client-side sorting, column filtering, and per-column security tier display rules.")
		<div class="component-page">
			<!-- Hero -->
			<section class="component-hero">
				<div class="component-hero-content">
					<h1>&lt;secure-table&gt;</h1>
					<p class="component-hero-description">
						A data table component with XSS-safe cell rendering, column injection prevention,
						and sanitized sort and filter inputs. Supports pagination, configurable page sizes,
						and optional sort and filter UI. All data is treated as untrusted and escaped
						before rendering.
					</p>
					<div class="component-hero-install">
						<pre><code class="language-markup">{ `<script type="module"
  src="/components/secure-table/secure-table.js">
</script>` }</code></pre>
					</div>
					<a href="/documentation/secure-table" class="component-hero-docs-link">View API Reference &#8594;</a>
				</div>
				<div class="component-hero-demo">
					<div class="component-hero-demo-label">Live Demo</div>
					<secure-table security-tier="public" sortable>
						<table slot="table">
							<thead>
								<tr>
									<th data-key="name" data-sortable="true">Name</th>
									<th data-key="role" data-sortable="true">Role</th>
									<th data-key="status" data-sortable="true">Status</th>
								</tr>
							</thead>
							<tbody>
								<tr><td>Alice</td><td>Admin</td><td>Active</td></tr>
								<tr><td>Bob</td><td>Editor</td><td>Active</td></tr>
								<tr><td>Carol</td><td>Viewer</td><td>Inactive</td></tr>
							</tbody>
						</table>
					</secure-table>
				</div>
			</section>

			<!-- How Data Works -->
			<section class="configs-section">
				<h2 class="configs-section-title">How to Provide Data</h2>
				<p class="configs-section-description">
					<code>&lt;secure-table&gt;</code> supports two data sources. The slotted HTML approach
					provides progressive enhancement — the table is readable without JavaScript. The
					programmatic approach is suited for dynamic or framework-managed data.
				</p>

				<div class="configs-grid configs-grid--2col">
					<div class="config-card">
						<div class="config-card-header"><span class="config-label">Slotted HTML (recommended)</span></div>
						<div class="config-card-desc">Server renders a standard <code>&lt;table slot="table"&gt;</code>. The component reads it on mount, builds an internal data model, then replaces the slot with an enhanced UI. Works without JavaScript.</div>
						<div class="data-flow" role="img" aria-label="Slotted HTML data flow: Server renders HTML, component reads on mount, enhanced UI">
							<div class="data-flow-step data-flow-step--server">
								<span class="data-flow-step-label">Server</span>
								<span class="data-flow-step-sub">Go renders</span>
							</div>
							<div class="data-flow-arrow" aria-hidden="true">&#8594;</div>
							<div class="data-flow-step">
								<span class="data-flow-step-label">&lt;table slot&gt;</span>
								<span class="data-flow-step-sub">light DOM</span>
							</div>
							<div class="data-flow-arrow" aria-hidden="true">&#8594;</div>
							<div class="data-flow-step">
								<span class="data-flow-step-label">mount</span>
								<span class="data-flow-step-sub">on connect</span>
							</div>
							<div class="data-flow-arrow" aria-hidden="true">&#8594;</div>
							<div class="data-flow-step data-flow-step--result">
								<span class="data-flow-step-label">sort&#xB7;filter</span>
								<span class="data-flow-step-sub">enhanced UI</span>
							</div>
						</div>
						<p class="data-flow-note data-flow-note--progressive">&#10003;&nbsp; Progressive enhancement — readable without JS</p>
						<div class="config-code">
							<pre><code class="language-markup">{ `<!-- Table data is in the light DOM.
     Component reads it on mount, then
     replaces it with an enhanced UI. -->
<secure-table security-tier="public" sortable>
  <table slot="table">
    <thead>
      <tr>
        <th data-key="name">Name</th>
        <th data-key="email">Email</th>
        <th data-key="role">Role</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td>Alice</td>
        <td>alice@example.com</td>
        <td>Admin</td>
      </tr>
    </tbody>
  </table>
</secure-table>` }</code></pre>
						</div>
					</div>

					<div class="config-card">
						<div class="config-card-header"><span class="config-label">Programmatic (JavaScript)</span></div>
						<div class="config-card-desc">Set <code>columns</code> and <code>data</code> as JS properties after the component connects. Use this for SPA data flows where rows arrive asynchronously or update reactively.</div>
						<div class="data-flow" role="img" aria-label="Programmatic data flow: import JS module, set columns schema, set data rows, component renders reactively">
							<div class="data-flow-step data-flow-step--js">
								<span class="data-flow-step-label">import()</span>
								<span class="data-flow-step-sub">JS module</span>
							</div>
							<div class="data-flow-arrow" aria-hidden="true">&#8594;</div>
							<div class="data-flow-step">
								<span class="data-flow-step-label">.columns</span>
								<span class="data-flow-step-sub">set schema</span>
							</div>
							<div class="data-flow-arrow" aria-hidden="true">&#8594;</div>
							<div class="data-flow-step">
								<span class="data-flow-step-label">.data</span>
								<span class="data-flow-step-sub">set rows</span>
							</div>
							<div class="data-flow-arrow" aria-hidden="true">&#8594;</div>
							<div class="data-flow-step data-flow-step--result">
								<span class="data-flow-step-label">Rendered</span>
								<span class="data-flow-step-sub">reactive</span>
							</div>
						</div>
						<p class="data-flow-note data-flow-note--reactive">&#8635;&nbsp; Reactive — reassign <code>.data</code> to update the table</p>
						<div class="config-code">
							<pre><code class="language-javascript">{ `// Set columns and data via JS properties
// after the component is connected to the DOM.
const table = document.querySelector('#myTable');

table.columns = [
  { key: 'name',  label: 'Name',  sortable: true },
  { key: 'email', label: 'Email', sortable: true },
  { key: 'role',  label: 'Role',  sortable: true },
];

table.data = [
  { name: 'Alice', email: 'alice@example.com', role: 'Admin' },
  { name: 'Bob',   email: 'bob@example.com',   role: 'Editor' },
];` }</code></pre>
						</div>
					</div>
				</div>
			</section>

			<!-- All Configurations -->
			<section class="configs-section">
				<h2 class="configs-section-title">Configurations</h2>
				<div class="configs-grid">

					<div class="config-card config-card--stagger">
						<div class="config-card-header"><span class="config-label">security-tier="public"</span></div>
						<div class="config-card-desc">XSS sanitization on all cells. No audit log. Use for catalog listings, search results, and reference data accessible without authentication.</div>
						<div class="config-demo">
							<secure-table security-tier="public">
								<table slot="table">
									<thead>
										<tr>
											<th data-key="id">ID</th>
											<th data-key="name">Name</th>
											<th data-key="city">City</th>
										</tr>
									</thead>
									<tbody>
										<tr><td>1</td><td>Alice</td><td>London</td></tr>
										<tr><td>2</td><td>Bob</td><td>Paris</td></tr>
										<tr><td>3</td><td>Carol</td><td>Berlin</td></tr>
									</tbody>
								</table>
							</secure-table>
						</div>
						<div class="config-code">
							<pre><code class="language-markup">{ `<secure-table security-tier="public">
  <table slot="table">
    <thead><tr>
      <th data-key="id">ID</th>
      <th data-key="name">Name</th>
    </tr></thead>
    <tbody>
      <tr><td>1</td><td>Alice</td></tr>
    </tbody>
  </table>
</secure-table>` }</code></pre>
						</div>
					</div>

					<div class="config-card config-card--stagger">
						<div class="config-card-header"><span class="config-label">security-tier="authenticated"</span></div>
						<div class="config-card-desc">Adds audit logging on sort, filter, and access events. Use for user lists, order history, and records only accessible to authenticated users.</div>
						<div class="config-demo">
							<secure-table security-tier="authenticated">
								<table slot="table">
									<thead>
										<tr>
											<th data-key="name">Name</th>
											<th data-key="department">Department</th>
											<th data-key="joined">Joined</th>
										</tr>
									</thead>
									<tbody>
										<tr><td>Alice</td><td>Engineering</td><td>2022-01-15</td></tr>
										<tr><td>Bob</td><td>Design</td><td>2022-03-20</td></tr>
										<tr><td>Carol</td><td>Engineering</td><td>2023-06-01</td></tr>
									</tbody>
								</table>
							</secure-table>
						</div>
						<div class="config-code">
							<pre><code class="language-markup">{ `<secure-table security-tier="authenticated">
  <table slot="table">...</table>
</secure-table>` }</code></pre>
						</div>
					</div>

					<div class="config-card config-card--stagger">
						<div class="config-card-header"><span class="config-label">security-tier="sensitive" — column masking</span></div>
						<div class="config-card-desc">Columns marked <code>data-tier="sensitive"</code> on the <code>&lt;th&gt;</code> display only the last 4 characters (<code>••••4321</code>). The full value is never written to the DOM.</div>
						<div class="config-demo">
							<secure-table security-tier="sensitive">
								<table slot="table">
									<thead>
										<tr>
											<th data-key="name">Name</th>
											<th data-key="email" data-tier="sensitive">Email</th>
											<th data-key="role">Role</th>
										</tr>
									</thead>
									<tbody>
										<tr><td>Alice</td><td>alice@example.com</td><td>Admin</td></tr>
										<tr><td>Bob</td><td>bob@example.com</td><td>Editor</td></tr>
										<tr><td>Carol</td><td>carol@example.com</td><td>Viewer</td></tr>
									</tbody>
								</table>
							</secure-table>
						</div>
						<div class="config-code">
							<pre><code class="language-markup">{ `<secure-table security-tier="sensitive">
  <table slot="table">
    <thead><tr>
      <th data-key="name">Name</th>
      <!-- data-tier on th masks this column -->
      <th data-key="email" data-tier="sensitive">
        Email
      </th>
    </tr></thead>
    ...
  </table>
</secure-table>` }</code></pre>
						</div>
					</div>

					<div class="config-card config-card--stagger">
						<div class="config-card-header"><span class="config-label">security-tier="critical" — full masking</span></div>
						<div class="config-card-desc">Columns marked <code>data-tier="critical"</code> are fully replaced with <code>••••••••</code>. Masked values cannot be selected, copied, or read by page scripts.</div>
						<div class="config-demo">
							<secure-table security-tier="critical">
								<table slot="table">
									<thead>
										<tr>
											<th data-key="name">Name</th>
											<th data-key="token" data-tier="critical">API Token</th>
											<th data-key="expires">Expires</th>
										</tr>
									</thead>
									<tbody>
										<tr><td>Alice</td><td>sk-abc123456789</td><td>2025-12-31</td></tr>
										<tr><td>Bob</td><td>sk-xyz987654321</td><td>2025-06-30</td></tr>
									</tbody>
								</table>
							</secure-table>
						</div>
						<div class="config-code">
							<pre><code class="language-markup">{ `<!-- data-tier="critical" on a column
     fully masks all cell values -->
<th data-key="token" data-tier="critical">
  API Token
</th>` }</code></pre>
						</div>
					</div>

					<div class="config-card config-card--stagger">
						<div class="config-card-header"><span class="config-label">sortable</span></div>
						<div class="config-card-desc">Add <code>data-sortable="true"</code> to individual <code>&lt;th&gt;</code> elements to enable click-to-sort on those columns. Sort state is reflected in column headers. Values sort as strings by default.</div>
						<div class="config-demo">
							<secure-table security-tier="public" sortable>
								<table slot="table">
									<thead>
										<tr>
											<th data-key="name" data-sortable="true">Name</th>
											<th data-key="score" data-sortable="true">Score</th>
											<th data-key="level" data-sortable="true">Level</th>
										</tr>
									</thead>
									<tbody>
										<tr><td>Alice</td><td>95</td><td>Senior</td></tr>
										<tr><td>Bob</td><td>82</td><td>Mid</td></tr>
										<tr><td>Carol</td><td>91</td><td>Senior</td></tr>
										<tr><td>Dave</td><td>74</td><td>Junior</td></tr>
									</tbody>
								</table>
							</secure-table>
						</div>
						<div class="config-code">
							<pre><code class="language-markup">{ `<secure-table security-tier="public" sortable>
  <table slot="table">
    <thead><tr>
      <th data-key="name" data-sortable="true">
        Name
      </th>
      <th data-key="score" data-sortable="true">
        Score
      </th>
    </tr></thead>
    ...
  </table>
</secure-table>` }</code></pre>
						</div>
					</div>

					<div class="config-card config-card--stagger">
						<div class="config-card-header"><span class="config-label">filterable</span></div>
						<div class="config-card-desc">Adds a search input above the table. <code>data-filterable="true"</code> on a <code>&lt;th&gt;</code> includes that column in the match. The filter input is sanitized before matching — XSS payloads entered as search terms are neutralized.</div>
						<div class="config-demo">
							<secure-table security-tier="public" filterable>
								<table slot="table">
									<thead>
										<tr>
											<th data-key="name" data-filterable="true">Name</th>
											<th data-key="dept" data-filterable="true">Department</th>
											<th data-key="location">Location</th>
										</tr>
									</thead>
									<tbody>
										<tr><td>Alice</td><td>Engineering</td><td>London</td></tr>
										<tr><td>Bob</td><td>Design</td><td>Paris</td></tr>
										<tr><td>Carol</td><td>Engineering</td><td>Berlin</td></tr>
										<tr><td>Dave</td><td>Marketing</td><td>London</td></tr>
										<tr><td>Eve</td><td>Design</td><td>Tokyo</td></tr>
									</tbody>
								</table>
							</secure-table>
						</div>
						<div class="config-code">
							<pre><code class="language-markup">{ `<secure-table security-tier="public" filterable>
  <table slot="table">
    <thead><tr>
      <!-- data-filterable includes this column -->
      <th data-key="name" data-filterable="true">
        Name
      </th>
      <!-- location column excluded from search -->
      <th data-key="location">Location</th>
    </tr></thead>
    ...
  </table>
</secure-table>` }</code></pre>
						</div>
					</div>

					<div class="config-card config-card--stagger">
						<div class="config-card-header"><span class="config-label">paginated</span></div>
						<div class="config-card-desc">Pagination activates automatically when row count exceeds the configured page size (default 10). Page controls appear below the table. Works with both slotted and programmatic data.</div>
						<div class="config-demo">
							<secure-table security-tier="public" sortable filterable>
								<table slot="table">
									<thead>
										<tr>
											<th data-key="name" data-sortable="true" data-filterable="true">Name</th>
											<th data-key="city" data-sortable="true" data-filterable="true">City</th>
											<th data-key="status" data-sortable="true">Status</th>
										</tr>
									</thead>
									<tbody>
										<tr><td>Alice</td><td>London</td><td>Active</td></tr>
										<tr><td>Bob</td><td>Paris</td><td>Active</td></tr>
										<tr><td>Carol</td><td>Berlin</td><td>Inactive</td></tr>
										<tr><td>Dave</td><td>Tokyo</td><td>Active</td></tr>
										<tr><td>Eve</td><td>Sydney</td><td>Active</td></tr>
										<tr><td>Frank</td><td>New York</td><td>Inactive</td></tr>
										<tr><td>Grace</td><td>Toronto</td><td>Active</td></tr>
										<tr><td>Henry</td><td>Dublin</td><td>Active</td></tr>
										<tr><td>Iris</td><td>Stockholm</td><td>Active</td></tr>
										<tr><td>Jack</td><td>Madrid</td><td>Inactive</td></tr>
										<tr><td>Karen</td><td>Vienna</td><td>Active</td></tr>
										<tr><td>Leo</td><td>Lisbon</td><td>Active</td></tr>
									</tbody>
								</table>
							</secure-table>
						</div>
						<div class="config-code">
							<pre><code class="language-markup">{ `<!-- Pagination activates automatically
     when row count exceeds page size (default 10).
     12 rows below → pagination shown. -->
<secure-table security-tier="public"
  sortable filterable>
  <table slot="table">
    <thead>...</thead>
    <tbody>
      <!-- 12 rows -->
    </tbody>
  </table>
</secure-table>` }</code></pre>
						</div>
					</div>

					<div class="config-card config-card--stagger">
						<div class="config-card-header"><span class="config-label">sortable + filterable combined</span></div>
						<div class="config-card-desc">All three features active together. The filter reduces the visible row set first, then sort is applied to the filtered result. Pagination reflects the filtered count.</div>
						<div class="config-demo">
							<secure-table security-tier="authenticated" sortable filterable>
								<table slot="table">
									<thead>
										<tr>
											<th data-key="name" data-sortable="true" data-filterable="true">Name</th>
											<th data-key="role" data-sortable="true" data-filterable="true">Role</th>
											<th data-key="status" data-sortable="true">Status</th>
											<th data-key="joined" data-sortable="true">Joined</th>
										</tr>
									</thead>
									<tbody>
										<tr><td>Alice</td><td>Admin</td><td>Active</td><td>2022-01</td></tr>
										<tr><td>Bob</td><td>Editor</td><td>Inactive</td><td>2022-03</td></tr>
										<tr><td>Carol</td><td>Viewer</td><td>Active</td><td>2023-06</td></tr>
										<tr><td>Dave</td><td>Editor</td><td>Active</td><td>2023-09</td></tr>
										<tr><td>Eve</td><td>Viewer</td><td>Inactive</td><td>2024-01</td></tr>
									</tbody>
								</table>
							</secure-table>
						</div>
						<div class="config-code">
							<pre><code class="language-markup">{ `<secure-table
  security-tier="authenticated"
  sortable
  filterable>
  <table slot="table">...</table>
</secure-table>` }</code></pre>
						</div>
					</div>

				</div>
			</section>

			<!-- Security Features -->
			<section class="security-section">
				<h2 class="security-section-title">Security Features</h2>
				<p class="security-callout">Security is enforced server-side. These features are client-side complements that reduce attack surface.</p>

				<!-- XSS / column injection panel -->
				<div class="security-telemetry-panel">
					<div class="security-telemetry-header">
						<span class="security-telemetry-title">XSS-safe rendering + column injection prevention</span>
						<span class="security-telemetry-badge">All tiers</span>
					</div>
					<p class="sel-enforcement-desc">
						The component never writes cell values directly to the DOM. All data passes through
						a text-content assignment — HTML entities are encoded before the cell is rendered.
						For slotted tables, the column schema is locked at mount time from the
						server-rendered <code>&lt;th data-key&gt;</code> elements. Attempts to inject
						additional columns via DOM manipulation after mount are ignored — only keys in
						the locked schema are rendered.
					</p>
					<div class="sel-enforcement-example">
						<div class="sel-enforcement-col">
							<div class="sel-enforcement-label">Injection attempt</div>
							<pre><code class="language-javascript">{ `// Attacker adds a new column to the DOM
const thead = document.querySelector('tr');
const th = document.createElement('th');
th.dataset.key = 'injectedCol';
th.textContent = '<script>alert(1)</script>';
thead.appendChild(th);` }</code></pre>
						</div>
						<div class="sel-enforcement-col">
							<div class="sel-enforcement-label sel-enforcement-label--success">Result</div>
							<pre><code class="language-javascript">{ `// Column schema is frozen at mount time.
// Columns added after mount are not rendered.
// Cell values are always text-content assigned:
//   cell.textContent = value  ✓
// Never:
//   cell.innerHTML = value    ✗` }</code></pre>
						</div>
					</div>
				</div>

				<table class="security-matrix">
					<thead>
						<tr>
							<th>Feature</th>
							<th><span class="tier-badge tier-badge--public">Public</span></th>
							<th><span class="tier-badge tier-badge--authenticated">Authenticated</span></th>
							<th><span class="tier-badge tier-badge--sensitive">Sensitive</span></th>
							<th><span class="tier-badge tier-badge--critical">Critical</span></th>
						</tr>
					</thead>
					<tbody>
						<tr>
							<td>XSS-safe cell rendering</td>
							<td class="matrix-yes">Yes</td>
							<td class="matrix-yes">Yes</td>
							<td class="matrix-yes">Yes</td>
							<td class="matrix-yes">Yes</td>
						</tr>
						<tr>
							<td>Column injection prevention</td>
							<td class="matrix-yes">Yes</td>
							<td class="matrix-yes">Yes</td>
							<td class="matrix-yes">Yes</td>
							<td class="matrix-yes">Yes</td>
						</tr>
						<tr>
							<td>Sort/filter input sanitization</td>
							<td class="matrix-yes">Yes</td>
							<td class="matrix-yes">Yes</td>
							<td class="matrix-yes">Yes</td>
							<td class="matrix-yes">Yes</td>
						</tr>
						<tr>
							<td>Audit logging</td>
							<td class="matrix-no">-</td>
							<td class="matrix-yes">Yes</td>
							<td class="matrix-yes">Yes</td>
							<td class="matrix-yes">Yes</td>
						</tr>
						<tr>
							<td>Sensitive column masking (last 4 visible)</td>
							<td class="matrix-no">-</td>
							<td class="matrix-no">-</td>
							<td class="matrix-yes">Yes</td>
							<td class="matrix-yes">Yes</td>
						</tr>
						<tr>
							<td>Critical column full masking</td>
							<td class="matrix-no">-</td>
							<td class="matrix-no">-</td>
							<td class="matrix-no">-</td>
							<td class="matrix-yes">Yes</td>
						</tr>
					</tbody>
				</table>
			</section>

