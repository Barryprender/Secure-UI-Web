<!-- FAQ Section -->
<section class="faq-section">
	<div class="container">
		<div class="section-header">
			<p class="section-eyebrow">Common questions</p>
			<h2 class="section-title">Frequently Asked Questions</h2>
		</div>
		<dl class="faq-list">
			<div class="faq-item">
				<dt class="faq-question">Can secure-telemetry-provider fully replace CAPTCHA?</dt>
				<dd class="faq-answer">For the majority of traffic, yes. Commodity bots — scrapers, credential stuffers, form spammers — are caught silently with no friction for real users. For sophisticated bots that mimic human behavior, use the risk score as a gate: serve CAPTCHA only when the score exceeds your threshold, typically 5–10% of requests. This eliminates the CAPTCHA burden for 90%+ of users while keeping a challenge in reserve for flagged sessions.</dd>
			</div>
			<div class="faq-item">
				<dt class="faq-question">How should I supply the signing key?</dt>
				<dd class="faq-answer">Use <code>setSigningKey()</code> — the key is stored in a private JS field and never appears in the DOM, making it invisible to <code>getAttribute()</code>, devtools inspection, and XSS. The <code>signing-key</code> HTML attribute is supported for backward compatibility: if present, it is automatically migrated to the private field and removed from the DOM on mount. Even with the private field, the key lives in JS memory — a same-page XSS or compromised script can still read it from the heap. For stronger integrity, rotate the key per-session from a server nonce endpoint.</dd>
			</div>
			<div class="faq-item">
				<dt class="faq-question">What risk score threshold should I use?</dt>
				<dd class="faq-answer">A common starting point: 0–30 allow, 31–60 log and optionally challenge, 61+ reject or require step-up authentication. Start permissive, log everything, then tighten based on real traffic patterns.</dd>
			</div>
			<div class="faq-item">
				<dt class="faq-question">Does behavioral scoring work on mobile?</dt>
				<dd class="faq-answer">Yes. Touch devices never produce mouse events, so the scoring function skips the mouse-movement penalty when <code>pointerType</code> is <code>touch</code> or <code>pen</code>. Timing and webdriver signals apply equally across all device types.</dd>
			</div>
			<div class="faq-item">
				<dt class="faq-question">Does Secure-UI work without JavaScript?</dt>
				<dd class="faq-answer">Yes. All components render as native HTML elements when JavaScript is unavailable. Client-side features — XSS sanitisation, rate limiting, audit logging — activate when JS is enabled. The page never breaks.</dd>
			</div>
			<div class="faq-item">
				<dt class="faq-question">What is a security tier?</dt>
				<dd class="faq-answer">A per-field declaration of data sensitivity: <code>public</code>, <code>authenticated</code>, <code>sensitive</code>, or <code>critical</code>. Set it via <code>security-tier="sensitive"</code>. The library automatically applies the corresponding protections — stricter rate limits, autocomplete suppression, enhanced audit logging.</dd>
			</div>
			<div class="faq-item">
				<dt class="faq-question">How does Secure-UI prevent XSS?</dt>
				<dd class="faq-answer">Every input component scans the raw field value on every keystroke against 8 injection patterns — script tags, <code>javascript:</code> URIs, inline event handlers, injected HTML elements, CSS expressions, VBScript URIs, <code>data:text/html</code> payloads, and template injection probes. The first match fires a <code>secure-threat-detected</code> event (raw value intentionally absent). Values are also sanitised via HTML entity encoding before emitting. The closed Shadow DOM prevents host-page scripts from reaching component internals.</dd>
			</div>
			<div class="faq-item">
				<dt class="faq-question">Is this a replacement for server-side validation?</dt>
				<dd class="faq-answer">No. Secure-UI is a client-side defence layer. Your server must still validate and sanitise all input — client-side controls can be bypassed. The components reduce boilerplate and enforce security by default, but server-side validation is always the security boundary.</dd>
			</div>
			<div class="faq-item">
				<dt class="faq-question">Does it work with React, Vue, Angular, or Next.js?</dt>
				<dd class="faq-answer">Yes. Web Components are a browser standard supported by all major frameworks. Import the library once with a single script tag, then use the element tags anywhere in your templates — React, Vue, Angular, Svelte, Next.js, Nuxt, Go Templ, Django, Rails, or plain HTML.</dd>
			</div>
			<div class="faq-item">
				<dt class="faq-question">How are CSRF tokens handled?</dt>
				<dd class="faq-answer"><code>&lt;secure-form&gt;</code> automatically fetches a CSRF token and injects it before each submission as both a request header and a hidden field. No manual token management required. The token is single-use and expires server-side.</dd>
			</div>
			<div class="faq-item">
				<dt class="faq-question">What makes this different from DOMPurify?</dt>
				<dd class="faq-answer">DOMPurify sanitises HTML strings as a post-processing step. Secure-UI is a complete form component library: CSRF defence, behavioral bot detection, audit logging, security tier enforcement, and input sanitisation are all part of the interaction model.</dd>
			</div>
			<div class="faq-item">
				<dt class="faq-question">Is there a CDN option?</dt>
				<dd class="faq-answer">Yes. Load directly from unpkg without installing anything: <code>&lt;script type="module" src="https://unpkg.com/secure-ui-components/dist/secure-ui.bundle.js"&gt;&lt;/script&gt;</code></dd>
			</div>
		</dl>
	</div>
</section>

<script type="module" nonce={ middleware.NonceFromContext(ctx) }>
// ── Demo form intercept ───────────────────────────────────────
{
  const formWrap   = document.getElementById('demo-form-wrap');
  const successEl  = document.getElementById('demo-success');
  const demoForm   = document.querySelector('#demo-panel secure-form');
  const resetBtn   = document.querySelector('.demo-reset-btn');

  const codeEl = document.getElementById('demo-success-code');

  function fmtMs(n) {
    if (n == null || (typeof n === 'number' && isNaN(n))) return null;
    if (n < 0) return 'none';
    return n + 'ms';
  }

  function syntaxHighlight(obj) {
    const str = JSON.stringify(obj, null, 2)
      .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
    return str.replace(
      /("(?:\\.|[^"\\])*"(?=\s*:))|("(?:\\.|[^"\\])*")|(true|false)|(null)|(-?\d+(?:\.\d+)?(?:[eE][+-]?\d+)?)/g,
      (_, key, str, bool, nil, num) => {
        if (key)  return '<span class="json-key">'  + key  + '</span>';
        if (str)  return '<span class="json-str">'  + str  + '</span>';
        if (bool) return '<span class="json-bool">' + bool + '</span>';
        if (nil)  return '<span class="json-null">' + nil  + '</span>';
        if (num)  return '<span class="json-num">'  + num  + '</span>';
        return _;
      }
    );
  }

  function jsonPanel(obj, signed) {
    const badge = signed
      ? '<span class="json-panel-badge"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg> signed</span>'
      : '';
    return '<div class="json-panel">' +
      '<div class="json-panel-bar">' +
        '<span class="json-panel-dots" aria-hidden="true"><i></i><i></i><i></i></span>' +
        '<span class="json-panel-title">telemetry.json</span>' +
        badge +
      '</div>' +
      '<pre class="json-panel-pre"><code class="json-panel-code">' + syntaxHighlight(obj) + '</code></pre>' +
      '</div>';
  }

  if (demoForm && formWrap && successEl) {
    demoForm.addEventListener('secure-form-submit', async (e) => {
      e.preventDefault();

      const tp = document.getElementById('home-tp');
      const tel = e.detail?.telemetry ?? {};
      const raw = e.detail?.formData ?? {};

      const envSignals = tp ? tp.collectSignals() : null;
      let envelope = null;
      if (tp && envSignals) {
        try { envelope = await tp.sign(envSignals); } catch {}
      }

      const riskScore = tel.riskScore ?? 0;
      const verdict = riskScore <= 30 ? 'ALLOW' : riskScore <= 60 ? 'REVIEW' : 'BLOCK';

      // Mask password values
      const capturedData = Object.fromEntries(
        Object.entries(raw).map(([k, v]) =>
          [k, k === 'password' ? '\u2022'.repeat(Math.min(String(v).length, 10)) : v]
        )
      );

      const obj = {};

      if (Object.keys(capturedData).length) obj.capturedData = capturedData;

      obj.risk = {
        score:   riskScore,
        verdict,
        signals: Array.isArray(tel.riskSignals) ? tel.riskSignals : [],
      };

      obj.session = {
        duration:   fmtMs(tel.sessionDuration),
        fieldCount: tel.fieldCount ?? null,
        fields: Array.isArray(tel.fields)
          ? tel.fields.map(f => ({
              name:        f.fieldName || f.fieldType || 'field',
              dwell:       fmtMs(f.dwell),
              velocity:    typeof f.velocity === 'number' ? parseFloat(f.velocity.toFixed(1)) : null,
              corrections: f.corrections ?? 0,
              paste:       f.pasteDetected ?? false,
              autofill:    f.autofillDetected ?? false,
            }))
          : [],
      };

      if (envSignals) {
        obj.environment = {
          webdriverDetected:        envSignals.webdriverDetected ?? false,
          headlessDetected:         envSignals.headlessDetected ?? false,
          domMutationDetected:      envSignals.domMutationDetected ?? false,
          injectedScriptCount:      envSignals.injectedScriptCount ?? 0,
          suspiciousScreenSize:     envSignals.suspiciousScreenSize ?? false,
          pointerType:              envSignals.pointerType ?? null,
          mouseMovementDetected:    envSignals.mouseMovementDetected ?? false,
          keyboardActivityDetected: envSignals.keyboardActivityDetected ?? false,
          pageLoadToFirstKeystroke: fmtMs(envSignals.pageLoadToFirstKeystroke),
          loadToSubmit:             fmtMs(envSignals.loadToSubmit),
        };
      }

      if (Array.isArray(tel.detectedThreats) && tel.detectedThreats.length) {
        obj.threats = tel.detectedThreats.map(t => ({ type: t.threatType, field: t.fieldName ?? null }));
      }

      if (envelope?.signature) {
        obj.envelope = {
          nonce:     envelope.nonce,
          issuedAt:  envelope.issuedAt,
          signature: envelope.signature,
        };
      }

      if (codeEl) codeEl.innerHTML = jsonPanel(obj, !!envelope?.signature);

      formWrap.hidden = true;
      successEl.classList.remove('demo-success--hidden');
    });

    resetBtn?.addEventListener('click', () => {
      successEl.classList.add('demo-success--hidden');
      formWrap.hidden = false;
      // reset signals panel
      const tf = document.getElementById('dls-threat-feed');
      if (tf) { tf.hidden = true; tf.innerHTML = ''; }
      document.querySelectorAll('.dls-sig-val').forEach(v => { v.textContent = '\u2014'; v.className = 'dls-sig-val'; });
      document.querySelectorAll('.dls-field-row').forEach(r => r.classList.remove('dls-field--threat'));
    });
  }
}

// ── Live signals panel — real component events ─────────────────
{
  const dlsThreatFeed = document.getElementById('dls-threat-feed');

  function updateDlsField(fieldName, tel) {
    const safe = fieldName.replace(/[^a-z0-9]/gi, '-');
    const velEl   = document.getElementById('dls-' + safe + '-velocity');
    const dwellEl = document.getElementById('dls-' + safe + '-dwell');
    const pasteEl = document.getElementById('dls-' + safe + '-paste');

    if (velEl && tel.velocity != null) {
      velEl.textContent = tel.velocity.toFixed(1) + '/s';
      velEl.classList.remove('dls-updated');
      void velEl.offsetWidth; // reflow to restart animation
      velEl.classList.add('dls-updated');
    }
    if (dwellEl && tel.dwell != null && tel.dwell >= 0) {
      dwellEl.textContent = tel.dwell + 'ms';
    }
    if (pasteEl) {
      const pasted = tel.pasteDetected === true;
      pasteEl.textContent = pasted ? 'yes' : 'no';
      pasteEl.className = 'dls-sig-val' + (pasted ? ' dls-val--warn' : '');
    }
  }

  function addThreatEntry(fieldName, patternId, tier) {
    if (!dlsThreatFeed) return;
    dlsThreatFeed.hidden = false;

    const entry = document.createElement('div');
    entry.className = 'dls-threat-entry';

    const icon = document.createElement('span');
    icon.className = 'dls-threat-icon';
    icon.setAttribute('aria-hidden', 'true');
    icon.textContent = '\u26A0';

    const text = document.createElement('span');
    text.className = 'dls-threat-text';

    const label = document.createElement('span');
    label.className = 'dls-threat-label';
    label.textContent = 'injection detected';

    const detail = document.createElement('span');
    detail.className = 'dls-threat-detail';
    detail.textContent = patternId + ' \u00B7 ' + fieldName + ' \u00B7 ' + tier;

    text.append(label, detail);
    entry.append(icon, text);
    dlsThreatFeed.prepend(entry);

    // cap at 3 entries
    while (dlsThreatFeed.children.length > 3) {
      dlsThreatFeed.lastElementChild?.remove();
    }

    // flash the field row
    const row = document.getElementById('dls-field-' + fieldName);
    if (row) {
      row.classList.add('dls-field--threat');
      setTimeout(() => row.classList.remove('dls-field--threat'), 2000);
    }
  }

  // Wire up input events on each live field
  document.querySelectorAll('#demo-panel secure-input').forEach(input => {
    input.addEventListener('secure-input-change', () => {
      const tel = typeof input.getFieldTelemetry === 'function' ? input.getFieldTelemetry() : null;
      if (tel) updateDlsField(input.getAttribute('name') ?? '', tel);
    });
  });

  // Injection detection — fired by the real component
  document.getElementById('home-tp')?.addEventListener('secure-threat-detected', e => {
    const { fieldName, patternId, tier } = e.detail ?? {};
    if (fieldName && patternId) addThreatEntry(String(fieldName), String(patternId), String(tier ?? ''));
  });
}

const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

// ── Install snippet copy ──────────────────────────────────────
{
  const copyBtn = document.getElementById('hero-install-copy');
  const cmdEl   = document.getElementById('hero-install-cmd');
  if (copyBtn && cmdEl) {
    copyBtn.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(cmdEl.textContent.trim());
        copyBtn.classList.add('hero-install-copy--copied');
        const orig = copyBtn.innerHTML;
        copyBtn.innerHTML = '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>';
        setTimeout(() => {
          copyBtn.classList.remove('hero-install-copy--copied');
          copyBtn.innerHTML = orig;
        }, 1800);
      } catch (_) {}
    });
  }
}

const themes = {
  default: {
    '--accent-primary': '#059669', '--accent-secondary': '#047857',
    '--accent-glow': 'rgba(5,150,105,0.12)', '--bg-primary': 'oklch(97.5% 0.006 240)',
    '--bg-secondary': 'oklch(95.5% 0.008 240)', '--bg-elevated': 'oklch(99% 0.003 240)',
    '--text-primary': 'oklch(15% 0.025 240)', '--text-secondary': 'oklch(42% 0.030 240)',
    '--border-subtle': 'oklch(88% 0.012 240)', '--border-medium': 'oklch(82% 0.016 240)',
    label: '/* Default theme — no overrides needed */',
  },
  dark: {
    '--accent-primary': '#6366f1', '--accent-secondary': '#4f46e5',
    '--accent-glow': 'rgba(99,102,241,0.15)', '--bg-primary': '#0a0a0f',
    '--bg-secondary': '#121218', '--bg-elevated': '#1c1c28',
    '--text-primary': '#f0f4ff', '--text-secondary': '#94a3b8',
    '--border-subtle': 'rgba(255,255,255,0.08)', '--border-medium': 'rgba(255,255,255,0.12)',
    label: ':root {\n  --accent-primary: #6366f1;\n  --bg-primary: #0a0a0f;\n  --text-primary: #f0f4ff;\n}',
  },
  ocean: {
    '--accent-primary': '#0284c7', '--accent-secondary': '#0369a1',
    '--accent-glow': 'rgba(2,132,199,0.12)', '--bg-primary': '#f0f9ff',
    '--bg-secondary': '#e0f2fe', '--bg-elevated': '#ffffff',
    '--text-primary': '#0c4a6e', '--text-secondary': '#0369a1',
    '--border-subtle': '#bae6fd', '--border-medium': '#7dd3fc',
    label: ':root {\n  --accent-primary: #0284c7;\n  --bg-primary: #f0f9ff;\n  --text-primary: #0c4a6e;\n}',
  },
  forest: {
    '--accent-primary': '#16a34a', '--accent-secondary': '#15803d',
    '--accent-glow': 'rgba(22,163,74,0.12)', '--bg-primary': '#f0fdf4',
    '--bg-secondary': '#dcfce7', '--bg-elevated': '#ffffff',
    '--text-primary': '#14532d', '--text-secondary': '#166534',
    '--border-subtle': '#bbf7d0', '--border-medium': '#86efac',
    label: ':root {\n  --accent-primary: #16a34a;\n  --bg-primary: #f0fdf4;\n  --text-primary: #14532d;\n}',
  },
  enterprise: {
    '--accent-primary': '#2563eb', '--accent-secondary': '#1d4ed8',
    '--accent-glow': 'rgba(37,99,235,0.10)', '--bg-primary': '#ffffff',
    '--bg-secondary': '#f8fafc', '--bg-elevated': '#ffffff',
    '--text-primary': '#0f172a', '--text-secondary': '#475569',
    '--border-subtle': '#e2e8f0', '--border-medium': '#cbd5e1',
    label: ':root {\n  --accent-primary: #2563eb;\n  --text-primary: #0f172a;\n}',
  },
};

const preview = document.getElementById('home-theme-preview');
const codeDisplay = document.getElementById('home-theme-code-display');
const tabs = document.querySelectorAll('.home-theme-tab');

function applyTheme(name) {
  const t = themes[name];
  if (!t || !preview) return;
  for (const [key, val] of Object.entries(t)) {
    if (key.startsWith('--')) preview.style.setProperty(key, val);
  }
  if (codeDisplay) codeDisplay.textContent = t.label;
}

tabs.forEach(tab => {
  tab.addEventListener('click', () => {
    tabs.forEach(t => { t.classList.remove('home-theme-tab--active'); t.setAttribute('aria-selected', 'false'); });
    tab.classList.add('home-theme-tab--active');
    tab.setAttribute('aria-selected', 'true');
    applyTheme(tab.dataset.theme ?? 'default');
  });
});

if (tabs.length > 0) {
  tabs[0].classList.add('home-theme-tab--active');
  applyTheme('default');
}

// ── Developer console greeting ────────────────────────────────
console.log(
  '%c⬡ Secure-UI',
  'color:#059669;font-size:18px;font-weight:800;letter-spacing:-0.02em;font-family:monospace'
);
console.log(
  '%cSecurity-hardened web components\nZero runtime dependencies · CSP-safe Shadow DOM · HMAC-signed telemetry',
  'color:#475569;font-size:12px;line-height:1.8;font-family:monospace'
);
console.log(
  '%c→ /components%c   10 components, fully interactive\n%c→ /documentation%c   Integration in under 5 minutes',
  'color:#059669;font-weight:600;font-size:12px;font-family:monospace',
  'color:#94a3b8;font-size:12px;font-family:monospace',
  'color:#059669;font-weight:600;font-size:12px;font-family:monospace',
  'color:#94a3b8;font-size:12px;font-family:monospace'
);

// ── Stat count-up ─────────────────────────────────────────────
function countUp(el, target) {
  const duration = 700;
  const start = performance.now();
  const step = (now) => {
    const p = Math.min((now - start) / duration, 1);
    const eased = 1 - Math.pow(1 - p, 3);
    el.textContent = Math.round(eased * target).toString();
    if (p < 1) requestAnimationFrame(step);
  };
  requestAnimationFrame(step);
}

// ── Scroll reveal — respects prefers-reduced-motion ───────────
if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
  const io = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.classList.add('is-visible');
        // Trigger count-up if this element contains a [data-count-to]
        const countEl = e.target.querySelector('[data-count-to]');
        if (countEl) countUp(countEl, parseInt(countEl.dataset.countTo, 10));
        io.unobserve(e.target);
      }
    });
  }, { threshold: 0.08, rootMargin: '0px 0px -24px 0px' });

  // Stagger children: JS sets --reveal-delay per child, adds .reveal, then observes
  document.querySelectorAll('[data-reveal-stagger]').forEach(parent => {
    Array.from(parent.children).forEach((child, i) => {
      child.style.setProperty('--reveal-delay', `${i * 75}ms`);
      child.classList.add('reveal');
      io.observe(child);
    });
  });

  // OWASP table: observe wrapper, CSS nth-child handles row stagger
  document.querySelectorAll('[data-reveal-rows]').forEach(el => io.observe(el));

  // Count-up elements not inside a stagger parent (e.g. stats strip)
  document.querySelectorAll('[data-count-to]').forEach(el => {
    if (!el.closest('[data-reveal-stagger]')) {
      const wrapper = el.closest('.stats-item') ?? el;
      const countIo = new IntersectionObserver(entries => {
        entries.forEach(e => {
          if (e.isIntersecting) {
            countUp(el, parseInt(el.dataset.countTo, 10));
            countIo.unobserve(e.target);
          }
        });
      }, { threshold: 0.5 });
      countIo.observe(wrapper);
    }
  });

  // Single .reveal elements added directly in HTML
  document.querySelectorAll('.reveal:not([style])').forEach(el => io.observe(el));
}

// ── Code block copy buttons ───────────────────────────────────
if (navigator.clipboard) {
  document.querySelectorAll('.code-example').forEach(block => {
    const header = block.querySelector('.code-header');
    const code = block.querySelector('code');
    if (!header || !code) return;

    const btn = document.createElement('button');
    btn.className = 'code-copy-btn';
    btn.textContent = 'Copy';
    btn.setAttribute('aria-label', 'Copy code to clipboard');

    btn.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(code.textContent ?? '');
        btn.textContent = 'Copied ✓';
        btn.classList.add('code-copy-btn--copied');
        setTimeout(() => {
          btn.textContent = 'Copy';
          btn.classList.remove('code-copy-btn--copied');
        }, 2000);
      } catch { /* clipboard access denied */ }
    });

    header.appendChild(btn);
  });
}

// ── Live telemetry signals — reflect visitor's actual behaviour ─
{
  const liveSignals = document.querySelectorAll('[data-live-signal]');
  const signalMap = new Map();
  liveSignals.forEach(el => signalMap.set(el.dataset.liveSignal, el));

  function updateSignal(name, value) {
    const el = signalMap.get(name);
    if (!el || el.textContent === value) return;
    el.textContent = value;
    el.classList.remove('signal-updated');
    void el.offsetWidth; // force reflow to restart animation
    el.classList.add('signal-updated');
  }

  document.addEventListener('mousemove', () => updateSignal('mouseMovementDetected', 'true'),
    { once: true, passive: true });

  document.addEventListener('keydown', () => updateSignal('keyboardActivityDetected', 'true'),
    { once: true, passive: true });
}

// ── Telemetry panel — continuous scenario loop ────────────────
{
  const panel     = document.getElementById('tel-panel');
  const sessionEl = document.getElementById('tel-session');
  const riskNumEl = document.getElementById('tel-risk-num');
  const fillEl    = document.getElementById('tel-risk-fill');
  const verdictEl = document.getElementById('tel-risk-verdict');
  const envEl     = document.getElementById('tel-envelope');

  if (panel && sessionEl && riskNumEl && !reduceMotion) {
    const rows = [...panel.querySelectorAll('[data-signal]')];

    const SCENARIOS = [
      {
        id: '#0f3a · human',
        signals: {
          webdriverDetected:        { v: 'false',   s: 'pass' },
          headlessDetected:         { v: 'false',   s: 'pass' },
          domMutationDetected:      { v: 'false',   s: 'pass' },
          injectedScriptCount:      { v: '0',       s: 'pass' },
          suspiciousScreenSize:     { v: 'false',   s: 'pass' },
          pointerType:              { v: '"mouse"', s: 'pass' },
          mouseMovementDetected:    { v: 'true',    s: 'pass' },
          keyboardActivityDetected: { v: 'true',    s: 'pass' },
        },
        risk: 8, verdict: 'ALLOW', hold: 3800,
      },
      {
        id: '#7c91 · suspicious',
        signals: {
          webdriverDetected:        { v: 'false',   s: 'pass' },
          headlessDetected:         { v: 'false',   s: 'pass' },
          domMutationDetected:      { v: 'true',    s: 'warn' },
          injectedScriptCount:      { v: '3',       s: 'warn' },
          suspiciousScreenSize:     { v: 'true',    s: 'warn' },
          pointerType:              { v: '"mouse"', s: 'pass' },
          mouseMovementDetected:    { v: 'false',   s: 'warn' },
          keyboardActivityDetected: { v: 'false',   s: 'warn' },
        },
        risk: 61, verdict: 'REVIEW', hold: 3200,
      },
      {
        id: '#2e58 · bot',
        signals: {
          webdriverDetected:        { v: 'true',    s: 'fail' },
          headlessDetected:         { v: 'true',    s: 'fail' },
          domMutationDetected:      { v: 'true',    s: 'fail' },
          injectedScriptCount:      { v: '12',      s: 'fail' },
          suspiciousScreenSize:     { v: 'true',    s: 'warn' },
          pointerType:              { v: '"none"',  s: 'warn' },
          mouseMovementDetected:    { v: 'false',   s: 'fail' },
          keyboardActivityDetected: { v: 'false',   s: 'fail' },
        },
        risk: 94, verdict: 'BLOCK', hold: 2600,
      },
    ];

    const sleep = ms => new Promise(r => setTimeout(r, ms));

    function randHex(n) {
      return Array.from({ length: n }, () => (Math.random() * 16 | 0).toString(16)).join('');
    }

    function applyRisk(val, verdict) {
      const color = val <= 30 ? '#10b981' : val <= 60 ? '#f59e0b' : '#ef4444';
      riskNumEl.textContent = val;
      riskNumEl.style.color = color;
      fillEl.style.width = val + '%';
      fillEl.style.background = color;
      verdictEl.textContent = verdict;
      verdictEl.className = 'tel-risk-verdict tel-risk-verdict--' + verdict.toLowerCase();
    }

    async function animateRisk(target, verdict) {
      const from = parseInt(riskNumEl.textContent, 10) || 0;
      const t0 = performance.now(), dur = 750;
      await new Promise(res => {
        const tick = now => {
          const p = Math.min((now - t0) / dur, 1);
          applyRisk(Math.round(from + (target - from) * (1 - Math.pow(1 - p, 3))), verdict);
          p < 1 ? requestAnimationFrame(tick) : res();
        };
        requestAnimationFrame(tick);
      });
    }

    function refreshEnvelope() {
      const ts = new Date().toISOString().slice(0, 19) + 'Z';
      envEl.textContent =
        '{ nonce: "' + randHex(8) + '...",\n' +
        '  issuedAt: "' + ts + '",\n' +
        '  signature: "' + randHex(14) + '..." }';
    }

    let idx = 0;
    async function loop() {
      // eslint-disable-next-line no-constant-condition
      while (true) {
        const sc = SCENARIOS[idx++ % SCENARIOS.length];
        sessionEl.textContent = 'Session ' + sc.id;

        for (const row of rows) {
          const sig = sc.signals[row.dataset.signal];
          if (!sig) continue;

          row.classList.add('tel-scanning');
          await sleep(160);

          const valEl = row.querySelector('.home-telemetry-signal-value');
          if (valEl && valEl.textContent !== sig.v) {
            valEl.classList.remove('tel-updating');
            void valEl.offsetWidth;
            valEl.textContent = sig.v;
            valEl.classList.add('tel-updating');
          }
          row.className = 'home-telemetry-signal home-telemetry-signal--' + sig.s;
          await sleep(30);
        }

        await sleep(120);
        await animateRisk(sc.risk, sc.verdict);

        if (sc.verdict === 'BLOCK') {
          panel.classList.remove('tel-blocked');
          void panel.offsetWidth;
          panel.classList.add('tel-blocked');
          await sleep(700);
          panel.classList.remove('tel-blocked');
        }

        refreshEnvelope();
        await sleep(sc.hold);
      }
    }

    // Lazy-start when panel scrolls into view
    const startIO = new IntersectionObserver(entries => {
      if (entries[0].isIntersecting) { startIO.disconnect(); setTimeout(loop, 900); }
    }, { threshold: 0.15 });
    startIO.observe(panel);
  }
}

// ── Hero demo panel ───────────────────────────────────────────
(function(){
  const hdWrap = document.getElementById('hd-wrap');
  if (!hdWrap) return;

  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  const wait = ms => new Promise(r => setTimeout(r, ms));
  const el = id => document.getElementById(id);

  async function typeField(tid, cid, bid, text, speed, cls) {
    const t = el(tid), c = el(cid), b = el(bid);
    t.textContent = ''; c.classList.add('vis');
    b.className = 'hd-fb ' + (speed === 'fast' ? 't' : speed === 'mobile' ? 'mt' : 'ht');
    for (let i = 0; i < text.length; i++) {
      t.textContent += text[i];
      if (speed === 'fast') await wait(14);
      else if (speed === 'mobile') await wait(55 + Math.random() * 70 + (Math.random() < .1 ? 180 : 0));
      else await wait(62 + Math.random() * 88 + (Math.random() < .07 ? 240 : 0));
    }
    c.classList.remove('vis');
    if (cls) b.className = 'hd-fb ' + cls;
  }

  function setBtn(text, bg, col, bc) {
    const b = el('hd-fbtn');
    b.textContent = text;
    b.style.background = bg; b.style.color = col; b.style.borderColor = bc;
    if (!reduceMotion) {
      b.classList.add('pulse');
      setTimeout(() => b.classList.remove('pulse'), 400);
    }
  }

  function showBadge(score, verdict, type) {
    const col = type === 'r' ? '#f87171' : '#00e5a0';
    const b = el('hd-badge');
    b.className = 'show ' + (type === 'r' ? 'r' : 'a');
    el('hd-badge-score').textContent = score;
    el('hd-badge-score').style.color = col;
    el('hd-badge-type').style.color = type === 'r' ? '#7a3a3a' : '#1a5a42';
    el('hd-badge-verdict').textContent = verdict;
    el('hd-badge-verdict').style.color = col;
  }

  function addHistoryDot(ok) {
    const d = document.createElement('div');
    d.className = 'hd-dot ' + (ok ? 'ok' : 'no');
    el('hd-history').appendChild(d);
  }

  function flashCard() {
    if (reduceMotion) return;
    const c = el('hd-card');
    c.classList.add('shake');
    setTimeout(() => c.classList.remove('shake'), 400);
  }

  function reset() {
    el('hd-card').className = '';
    el('hd-ftitle').textContent = 'sign in'; el('hd-ftitle').style.color = '#5a6a82';
    el('hd-fe').className = 'hd-fb'; el('hd-fp').className = 'hd-fb';
    el('hd-et').textContent = ''; el('hd-pt').textContent = '';
    el('hd-ec').classList.remove('vis'); el('hd-pc').classList.remove('vis');
    el('hd-lk').style.stroke = '#3a4a62';
    el('hd-fbtn').style.cssText = ''; el('hd-fbtn').textContent = 'submit';
    el('hd-sb').textContent = ''; el('hd-sb').className = '';
    el('hd-badge').className = '';
    el('hd-badge-score').textContent = '—'; el('hd-badge-score').style.color = '#2a3a52';
    el('hd-badge-type').style.color = '#2a3a52';
    el('hd-badge-verdict').textContent = '—'; el('hd-badge-verdict').style.color = '#2a3a52';
  }

  const SC = [
    {
      kind:'bot', label:'SQLi bot',
      email:"admin@target.com", pass:"' OR 1=1 --",
      speed:'fast', statusA:'bot connecting...', statusB:'no human interaction signals',
      score:'94/100', verdict:'REJECT', vt:'r',
      fxType:'attack', fxN:22,
      emailCls:'d', passCls:'d',
      btnA:['submitting...','rgba(248,113,113,0.12)','#f87171','rgba(248,113,113,0.3)'],
      btnB:['blocked by secure-ui','rgba(248,113,113,0.1)','#f87171','rgba(248,113,113,0.3)'],
      finalTitle:'threat blocked', titleCol:'#f87171', lockCol:'#f87171',
      finalSb:'request rejected', sbCls:'w', cardFinal:'blocked', shake:true,
    },
    {
      kind:'human', label:'alice@acme.com',
      email:"alice@acme.com", pass:"••••••••••",
      speed:'slow', statusA:'', statusB:'',
      score:'3/100', verdict:'ALLOW', vt:'a',
      fxType:'safe', fxN:10,
      emailCls:'', passCls:'',
      btnA:['verifying...','rgba(80,120,180,0.1)','#5a8aaa','#2a3a55'],
      btnB:['access granted','rgba(0,229,160,0.1)','#00e5a0','rgba(0,229,160,0.3)'],
      finalTitle:'welcome back', titleCol:'#00e5a0', lockCol:'#00e5a0',
      finalSb:'verified — signed in', sbCls:'ok', cardFinal:'allowed', shake:false,
    },
    {
      kind:'bot', label:'credential stuffer',
      email:"user@gmail.com", pass:"password123",
      speed:'fast', statusA:'bot connecting...', statusB:'no interaction signals',
      score:'71/100', verdict:'REJECT', vt:'r',
      fxType:'attack', fxN:20,
      emailCls:'d', passCls:'d',
      btnA:['submitting...','rgba(248,113,113,0.12)','#f87171','rgba(248,113,113,0.3)'],
      btnB:['blocked by secure-ui','rgba(248,113,113,0.1)','#f87171','rgba(248,113,113,0.3)'],
      finalTitle:'threat blocked', titleCol:'#f87171', lockCol:'#f87171',
      finalSb:'request rejected', sbCls:'w', cardFinal:'blocked', shake:true,
    },
    {
      kind:'mobile', label:'mobile user — touch',
      email:"dan@example.com", pass:"••••••••••••",
      speed:'mobile', statusA:'', statusB:'',
      score:'5/100', verdict:'ALLOW', vt:'a',
      fxType:'mobile', fxN:12,
      emailCls:'', passCls:'',
      btnA:['verifying...','rgba(80,120,180,0.1)','#5a8aaa','#2a3a55'],
      btnB:['access granted','rgba(0,229,160,0.1)','#00e5a0','rgba(0,229,160,0.3)'],
      finalTitle:'welcome back', titleCol:'#00e5a0', lockCol:'#00e5a0',
      finalSb:'touch user verified', sbCls:'ok', cardFinal:'allowed', shake:false,
    },
    {
      kind:'bot', label:'headless scraper',
      email:"test@test.com", pass:"<script>alert(1)<\/script>",
      speed:'fast', statusA:'bot connecting...', statusB:'injection pattern detected',
      score:'80/100', verdict:'REJECT', vt:'r',
      fxType:'attack', fxN:22,
      emailCls:'d', passCls:'d',
      btnA:['submitting...','rgba(248,113,113,0.12)','#f87171','rgba(248,113,113,0.3)'],
      btnB:['blocked by secure-ui','rgba(248,113,113,0.1)','#f87171','rgba(248,113,113,0.3)'],
      finalTitle:'threat blocked', titleCol:'#f87171', lockCol:'#f87171',
      finalSb:'request rejected', sbCls:'w', cardFinal:'blocked', shake:true,
    },
    {
      kind:'human', label:'carol@corp.net',
      email:"carol@corp.net", pass:"••••••••••••",
      speed:'slow', statusA:'', statusB:'',
      score:'2/100', verdict:'ALLOW', vt:'a',
      fxType:'safe', fxN:10,
      emailCls:'', passCls:'',
      btnA:['verifying...','rgba(80,120,180,0.1)','#5a8aaa','#2a3a55'],
      btnB:['access granted','rgba(0,229,160,0.1)','#00e5a0','rgba(0,229,160,0.3)'],
      finalTitle:'welcome back', titleCol:'#00e5a0', lockCol:'#00e5a0',
      finalSb:'verified — signed in', sbCls:'ok', cardFinal:'allowed', shake:false,
    },
  ];

  async function run() {
    let i = 0;
    while (true) {
      const s = SC[i % SC.length];
      const idx = i % SC.length;
      if (idx === 0) el('hd-history').innerHTML = '';
      el('hd-rc').textContent = `attempt ${idx+1} of ${SC.length}`;
      el('hd-rc').className = 'lit';

      reset();
      await wait(380);

      if (s.kind === 'bot') {
        el('hd-sb').textContent = s.statusA; el('hd-sb').className = 'w';
        el('hd-card').className = 'bot';
        await wait(360);
      } else if (s.kind === 'mobile') {
        el('hd-sb').textContent = 'touch device detected'; el('hd-sb').className = 'i';
        el('hd-card').className = 'human';
        await wait(260);
      } else {
        el('hd-card').className = 'human';
      }

      await typeField('hd-et','hd-ec','hd-fe', s.email, s.speed, s.emailCls);
      await wait(s.kind === 'bot' ? 70 : 140);
      await typeField('hd-pt','hd-pc','hd-fp', s.pass, s.speed, s.passCls);
      await wait(s.kind === 'bot' ? 140 : 260);

      if (s.statusB) el('hd-sb').textContent = s.statusB;
      setBtn(...s.btnA);

      await wait(320);
      showBadge(s.score, s.verdict, s.vt);

      await wait(400);

      if (s.shake) flashCard();
      await wait(s.shake ? 180 : 0);

      el('hd-card').className = s.cardFinal;

      if (s.kind === 'bot') {
        el('hd-fe').className = 'hd-fb d';
        el('hd-fp').className = 'hd-fb d';
      } else {
        el('hd-fe').className = 'hd-fb s';
        el('hd-et').textContent = s.email;
        el('hd-fp').className = 'hd-fb s';
        el('hd-pt').textContent = s.pass;
      }

      setBtn(...s.btnB);
      el('hd-sb').textContent = s.finalSb; el('hd-sb').className = s.sbCls;
      el('hd-ftitle').textContent = s.finalTitle; el('hd-ftitle').style.color = s.titleCol;
      el('hd-lk').style.stroke = s.lockCol;

      addHistoryDot(s.kind !== 'bot');

      const isLast = idx === SC.length - 1;
      if (isLast) {
        el('hd-rc').textContent = '4 blocked · 2 allowed — looping';
        await wait(2600);
      } else {
        await wait(2000);
      }
      i++;
    }
  }

  run();
})();
</script>
	}
}
