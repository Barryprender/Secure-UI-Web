package pages

import (
	"secure-ui-showcase-go/internal/i18n"
	"secure-ui-showcase-go/internal/middleware"
	"secure-ui-showcase-go/internal/templates"
)

templ Home(signingKey string) {
	@templates.Layout("Secure-UI — Secure UI Components with Bot Detection, CSRF & XSS Protection.", "Drop-in secure UI components with CSRF protection, XSS prevention, behavioral bot detection, and HMAC-signed telemetry. Zero dependencies. MIT licence. Works with any framework.", true, []string{"/static/styles/home/home.min.css"}, "secure-file-upload", "secure-form", "secure-input", "secure-submit-button", "secure-telemetry-provider", "secure-textarea") {
		@templates.HomeJsonLDScript()
		@templates.HomeFAQJsonLDScript()
		<!-- Hero Section -->
<section class="hero-section">
	<div class="container">
		<div class="hero-inner">
			<div class="hero-content">
				<p class="hero-eyebrow">
					<span class="hero-eyebrow-dot" aria-hidden="true"></span>
					{ i18n.T(ctx, "home.hero.eyebrow") }
				</p>

				<h1 class="hero-title" id="hero-title">
					<span>{ i18n.T(ctx, "home.hero.line1") }</span><br/>
					<span>{ i18n.T(ctx, "home.hero.line2") }</span><br/>
					<em>{ i18n.T(ctx, "home.hero.line3") }</em>
				</h1>

				<p class="hero-description">{ i18n.T(ctx, "home.hero.desc") }</p>

				<div class="hero-cta" id="hero-cta">
					<a href="/documentation" class="btn btn-primary hero-btn-primary">
						{ i18n.T(ctx, "home.hero.cta_explore") }
						<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
					</a>
					<a href="https://secure-ui-angular.fly.dev/" class="btn btn-secondary hero-btn-framework" target="_blank" rel="noopener noreferrer">
						<svg width="16" height="17" viewBox="0 0 200 211.7" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
							<defs>
								<linearGradient id="hng-a" x1="49.009" x2="225.83" y1="213.75" y2="129.72" gradientUnits="userSpaceOnUse">
									<stop stop-color="#E40035" offset="0"/>
									<stop stop-color="#F60A48" offset=".24"/>
									<stop stop-color="#F20755" offset=".352"/>
									<stop stop-color="#DC087D" offset=".494"/>
									<stop stop-color="#9717E7" offset=".745"/>
									<stop stop-color="#6C00F5" offset="1"/>
								</linearGradient>
								<linearGradient id="hng-b" x1="41.025" x2="156.74" y1="28.344" y2="160.34" gradientUnits="userSpaceOnUse">
									<stop stop-color="#FF31D9" offset="0"/>
									<stop stop-color="#FF5BE1" stop-opacity="0" offset="1"/>
								</linearGradient>
								<clipPath id="hng-c"><path d="M0 0h223v236H0z"/></clipPath>
							</defs>
							<g transform="scale(.90059)" clip-path="url(#hng-c)">
								<path d="m222.08 39.192-8.019 125.92-76.671-165.12zm-53.105 162.82-57.933 33.056-57.934-33.056 11.783-28.556h92.301zm-57.933-139.34 30.357 73.803h-60.715zm-103.1 102.44-7.937-125.92 84.69-39.192z" fill="url(#hng-a)"/>
								<path d="m222.08 39.192-8.019 125.92-76.671-165.12zm-53.105 162.82-57.933 33.056-57.934-33.056 11.783-28.556h92.301zm-57.933-139.34 30.357 73.803h-60.715zm-103.1 102.44-7.937-125.92 84.69-39.192z" fill="url(#hng-b)"/>
							</g>
						</svg>
						Angular demo
					</a>
					<a href="https://secure-ui-react.fly.dev/" class="btn btn-secondary hero-btn-framework" target="_blank" rel="noopener noreferrer">
						<svg width="15" height="15" viewBox="-11.5 -10.232 23 20.463" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
							<circle r="2.05" fill="currentColor"/>
							<ellipse rx="11" ry="4.2" stroke="currentColor" stroke-width="1.2"/>
							<ellipse rx="11" ry="4.2" stroke="currentColor" stroke-width="1.2" transform="rotate(60)"/>
							<ellipse rx="11" ry="4.2" stroke="currentColor" stroke-width="1.2" transform="rotate(120)"/>
						</svg>
						React demo
					</a>
				</div>
				<p class="hero-licence">MIT Licence · Free forever</p>

				<div class="hero-install" id="hero-install">
					<span class="hero-install-prompt" aria-hidden="true">$</span>
					<code class="hero-install-cmd" id="hero-install-cmd">{ i18n.T(ctx, "home.hero.install") }</code>
					<button class="hero-install-copy" id="hero-install-copy" aria-label="Copy install command" type="button">
						<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
					</button>
				</div>

				<div class="hero-trust" role="list" aria-label="Key facts">
					<div class="hero-trust-item" role="listitem">
						<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>
						{ i18n.T(ctx, "home.hero.trust_deps") }
					</div>
					<div class="hero-trust-item" role="listitem">
						<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>
						{ i18n.T(ctx, "home.hero.trust_mit") }
					</div>
					<div class="hero-trust-item" role="listitem">
						<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>
						{ i18n.T(ctx, "home.hero.trust_comp") }
					</div>
					<div class="hero-trust-item" role="listitem">
						<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>
						{ i18n.T(ctx, "home.hero.trust_fw") }
					</div>
				</div>
			</div>

			<!-- Live Demo Panel -->
			<aside class="hero-demo-panel" aria-hidden="true">
				<div id="hd-wrap">
					<div id="hd-stage">
						<div id="hd-card">
							<div class="hd-logo">
								<svg id="hd-lk" viewBox="0 0 14 14"><rect x="2" y="6" width="10" height="7" rx="2"/><path d="M4.5 6V4.5a2.5 2.5 0 0 1 5 0V6"/></svg>
							</div>
							<div id="hd-ftitle">sign in</div>
							<div class="hd-fl">email</div>
							<div class="hd-fb" id="hd-fe"><span id="hd-et"></span><span class="hd-cur" id="hd-ec"></span></div>
							<div class="hd-fl">password</div>
							<div class="hd-fb" id="hd-fp"><span id="hd-pt"></span><span class="hd-cur" id="hd-pc"></span></div>
							<button id="hd-fbtn" tabindex="-1">submit</button>
							<div id="hd-sb"></div>
						</div>
						<div id="hd-badge">
							<div id="hd-badge-left">
								<div id="hd-badge-type">risk score</div>
								<div id="hd-badge-score">—</div>
							</div>
							<div id="hd-badge-verdict">—</div>
						</div>
						<div id="hd-history"></div>
						<div id="hd-rc"></div>
					</div>
				</div>
			</aside>
		</div>
	</div>
</section>

<!-- Stats Strip -->
<section class="stats-strip" aria-label="Key facts">
	<div class="container">
		<div class="stats-list">
			<a href="/documentation" class="stats-item">
				<strong>Zero</strong>
				<span>{ i18n.T(ctx, "home.stats.deps") }</span>
			</a>
			<a href="/telemetry" class="stats-item">
				<strong data-count-to="9">0</strong>
				<span>{ i18n.T(ctx, "home.stats.signals") }</span>
			</a>
			<a href="/telemetry" class="stats-item">
				<strong>HMAC</strong>
				<span>{ i18n.T(ctx, "home.stats.signed") }</span>
			</a>
			<a href="#owasp" class="stats-item">
				<strong>A01–A10</strong>
				<span>{ i18n.T(ctx, "home.stats.owasp") }</span>
			</a>
		</div>
	</div>
</section>

<!-- Live Demo Section -->
<section class="demo-section">
	<div class="container">
		<div class="demo-inner" data-reveal-stagger>
			<div class="demo-content">
				<p class="demo-label">{ i18n.T(ctx, "home.demo.label") }</p>
				<h2 class="demo-heading">{ i18n.T(ctx, "home.demo.heading") }<br/>{ i18n.T(ctx, "home.demo.subheading") }</h2>
				<p class="demo-body">{ i18n.T(ctx, "home.demo.body") }</p>
				<a href="/components" class="demo-link">
					{ i18n.T(ctx, "home.demo.link") }
					<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
				</a>
			</div>

			<div class="demo-component-panel" id="demo-panel">
				<div class="demo-component-panel-header">
					<span class="demo-panel-title">{ i18n.T(ctx, "home.demo.panel_title") }</span>
					<span class="demo-panel-badge">{ i18n.T(ctx, "home.demo.panel_live") }</span>
				</div>
				<div id="demo-form-wrap">
					<secure-telemetry-provider id="home-tp" signing-key={ signingKey }>
						<secure-form action="#" method="POST" use-fetch>
							<secure-input
								name="email"
								type="email"
								label="Email address"
								security-tier="authenticated"
								required>
							</secure-input>
							<secure-input
								name="password"
								type="password"
								label="Password"
								security-tier="critical"
								min-length="8"
								required>
							</secure-input>
							<div class="demo-form-submit-wrapper">
								<button type="submit" class="btn btn-primary">{ i18n.T(ctx, "home.demo.submit") }</button>
							</div>
						</secure-form>
					</secure-telemetry-provider>

					<!-- Live signals panel — driven by real component events -->
					<div id="demo-live-signals" class="demo-live-signals" aria-label="Live telemetry signals">
						<div class="dls-header">
							<span class="dls-dot" aria-hidden="true"></span>
							<span class="dls-label">Live signals</span>
						</div>
						<div class="dls-fields">
							<div class="dls-field-row" id="dls-field-email">
								<span class="dls-field-name">email</span>
								<span class="dls-sig"><span class="dls-sig-key">vel</span><span class="dls-sig-val" id="dls-email-velocity">&mdash;</span></span>
								<span class="dls-sig"><span class="dls-sig-key">dwell</span><span class="dls-sig-val" id="dls-email-dwell">&mdash;</span></span>
								<span class="dls-sig"><span class="dls-sig-key">paste</span><span class="dls-sig-val" id="dls-email-paste">&mdash;</span></span>
							</div>
							<div class="dls-field-row" id="dls-field-password">
								<span class="dls-field-name">password</span>
								<span class="dls-sig"><span class="dls-sig-key">vel</span><span class="dls-sig-val" id="dls-password-velocity">&mdash;</span></span>
								<span class="dls-sig"><span class="dls-sig-key">dwell</span><span class="dls-sig-val" id="dls-password-dwell">&mdash;</span></span>
								<span class="dls-sig"><span class="dls-sig-key">paste</span><span class="dls-sig-val" id="dls-password-paste">&mdash;</span></span>
							</div>
						</div>
						<div id="dls-threat-feed" class="dls-threat-feed" hidden></div>
					</div>
				</div>
				<div id="demo-success" class="demo-success demo-success--hidden" aria-live="polite">
					<svg class="demo-success-icon" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="9 12 11 14 15 10"/></svg>
					<p class="demo-success-title">Submitted securely</p>
					<div id="demo-success-code"></div>
					<button class="btn btn-secondary demo-reset-btn">Reset demo</button>
				</div>
			</div>
		</div>
	</div>
</section>

<!-- Behavioral Intelligence Section -->
<section class="home-telemetry-section">
	<div class="container">
		<div class="home-telemetry-inner" data-reveal-stagger>
			<div class="home-telemetry-content">
				<span class="home-telemetry-badge">{ i18n.T(ctx, "home.tel.badge") }</span>
				<h2>{ i18n.T(ctx, "home.tel.title") }<br/><em>{ i18n.T(ctx, "home.tel.title_em") }</em></h2>
				<p>{ i18n.T(ctx, "home.tel.desc") }</p>
				<ul class="home-telemetry-differentiators">
					<li>{ i18n.T(ctx, "home.tel.li1") }</li>
					<li>{ i18n.T(ctx, "home.tel.li2") }</li>
					<li>{ i18n.T(ctx, "home.tel.li3") }</li>
					<li>{ i18n.T(ctx, "home.tel.li4") }</li>
					<li>{ i18n.T(ctx, "home.tel.li5") }</li>
				</ul>
				<a href="/telemetry" class="btn btn-primary">{ i18n.T(ctx, "home.tel.cta") }</a>
			</div>
			<div class="home-telemetry-panel" id="tel-panel" aria-hidden="true">
				<div class="home-telemetry-panel-header">
					<span class="home-telemetry-panel-dot"></span>
					<span class="home-telemetry-panel-live">LIVE</span>
					Environmental Signals
					<span class="tel-session-id" id="tel-session">Session #0f3a</span>
				</div>
				<div class="home-telemetry-signals">
					<div class="home-telemetry-signal home-telemetry-signal--pass" data-signal="webdriverDetected">
						<span class="home-telemetry-signal-name">webdriverDetected</span>
						<span class="home-telemetry-signal-value">false</span>
						<span class="home-telemetry-signal-status"></span>
					</div>
					<div class="home-telemetry-signal home-telemetry-signal--pass" data-signal="headlessDetected">
						<span class="home-telemetry-signal-name">headlessDetected</span>
						<span class="home-telemetry-signal-value">false</span>
						<span class="home-telemetry-signal-status"></span>
					</div>
					<div class="home-telemetry-signal home-telemetry-signal--pass" data-signal="domMutationDetected">
						<span class="home-telemetry-signal-name">domMutationDetected</span>
						<span class="home-telemetry-signal-value">false</span>
						<span class="home-telemetry-signal-status"></span>
					</div>
					<div class="home-telemetry-signal home-telemetry-signal--pass" data-signal="injectedScriptCount">
						<span class="home-telemetry-signal-name">injectedScriptCount</span>
						<span class="home-telemetry-signal-value">0</span>
						<span class="home-telemetry-signal-status"></span>
					</div>
					<div class="home-telemetry-signal home-telemetry-signal--pass" data-signal="suspiciousScreenSize">
						<span class="home-telemetry-signal-name">suspiciousScreenSize</span>
						<span class="home-telemetry-signal-value">false</span>
						<span class="home-telemetry-signal-status"></span>
					</div>
					<div class="home-telemetry-signal home-telemetry-signal--pass" data-signal="pointerType">
						<span class="home-telemetry-signal-name">pointerType</span>
						<span class="home-telemetry-signal-value">"mouse"</span>
						<span class="home-telemetry-signal-status"></span>
					</div>
					<div class="home-telemetry-signal home-telemetry-signal--pass" data-signal="mouseMovementDetected">
						<span class="home-telemetry-signal-name">mouseMovementDetected</span>
						<span class="home-telemetry-signal-value">false</span>
						<span class="home-telemetry-signal-status"></span>
					</div>
					<div class="home-telemetry-signal home-telemetry-signal--pass" data-signal="keyboardActivityDetected">
						<span class="home-telemetry-signal-name">keyboardActivityDetected</span>
						<span class="home-telemetry-signal-value">false</span>
						<span class="home-telemetry-signal-status"></span>
					</div>
				</div>
				<div class="home-telemetry-risk" id="tel-risk">
					<div class="tel-risk-row">
						<span class="tel-risk-label">RISK SCORE</span>
						<span class="tel-risk-num" id="tel-risk-num">8</span>
						<span class="tel-risk-verdict tel-risk-verdict--allow" id="tel-risk-verdict">ALLOW</span>
					</div>
					<div class="tel-risk-track">
						<div class="tel-risk-fill" id="tel-risk-fill"></div>
					</div>
				</div>
				<div class="home-telemetry-envelope">
					<div class="home-telemetry-envelope-label">HMAC-SHA-256 signed envelope</div>
					<pre id="tel-envelope">{ `{ nonce: "a3f8b2c1...",
  issuedAt: "2026-03-17T14:32:07Z",
  signature: "7c2bef09a1d3..." }` }</pre>
				</div>
			</div>
		</div>
	</div>
</section>

<!-- Built-in Security Features Section -->
<section class="features-section">
	<div class="container">
		<div class="section-header">
			<p class="section-eyebrow">{ i18n.T(ctx, "home.feat.eyebrow") }</p>
			<h2 class="section-title">{ i18n.T(ctx, "home.feat.title") }</h2>
			<p class="section-description">{ i18n.T(ctx, "home.feat.desc") }</p>
		</div>

		<div class="features-grid" data-reveal-stagger>
			<!-- 1. Closed Shadow DOM — green: isolation/locked -->
			<div class="feature-card">
				<div class="feature-icon" aria-hidden="true">
					<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
						<path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
						<line x1="12" y1="16" x2="12" y2="16.01"></line>
					</svg>
				</div>
				<h3 class="feature-title">{ i18n.T(ctx, "home.feat.shadowdom.title") }</h3>
				<p class="feature-description">{ i18n.T(ctx, "home.feat.shadowdom.desc") }</p>
				<ul class="feature-list">
					<li>{ i18n.T(ctx, "home.feat.shadowdom.li1") }</li>
					<li>{ i18n.T(ctx, "home.feat.shadowdom.li2") }</li>
					<li>{ i18n.T(ctx, "home.feat.shadowdom.li3") }</li>
				</ul>
			</div>

			<!-- 2. Behavioral Telemetry — indigo: intelligence/detection -->
			<div class="feature-card">
				<div class="feature-icon feature-icon--indigo" aria-hidden="true">
					<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline>
					</svg>
				</div>
				<h3 class="feature-title">{ i18n.T(ctx, "home.feat.captcha.title") }</h3>
				<p class="feature-description">{ i18n.T(ctx, "home.feat.captcha.desc") }</p>
				<ul class="feature-list">
					<li>{ i18n.T(ctx, "home.feat.captcha.li1") }</li>
					<li>{ i18n.T(ctx, "home.feat.captcha.li2") }</li>
					<li>{ i18n.T(ctx, "home.feat.captcha.li3") }</li>
				</ul>
			</div>

			<!-- 3. Audit Trail — teal: recording/compliance -->
			<div class="feature-card">
				<div class="feature-icon feature-icon--teal" aria-hidden="true">
					<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"></path>
						<rect x="8" y="2" width="8" height="4" rx="1" ry="1"></rect>
						<line x1="8" y1="10" x2="16" y2="10"></line>
						<line x1="8" y1="14" x2="16" y2="14"></line>
						<line x1="8" y1="18" x2="12" y2="18"></line>
					</svg>
				</div>
				<h3 class="feature-title">{ i18n.T(ctx, "home.feat.audit.title") }</h3>
				<p class="feature-description">{ i18n.T(ctx, "home.feat.audit.desc") }</p>
				<ul class="feature-list">
					<li>{ i18n.T(ctx, "home.feat.audit.li1") }</li>
					<li>{ i18n.T(ctx, "home.feat.audit.li2") }</li>
					<li>{ i18n.T(ctx, "home.feat.audit.li3") }</li>
				</ul>
			</div>

			<!-- 4. CSRF Protection — blue: trust/auth boundary -->
			<div class="feature-card">
				<div class="feature-icon feature-icon--blue" aria-hidden="true">
					<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
						<path d="m9 12 2 2 4-4"></path>
					</svg>
				</div>
				<h3 class="feature-title">{ i18n.T(ctx, "home.feat.csrf.title") }</h3>
				<p class="feature-description">{ i18n.T(ctx, "home.feat.csrf.desc") }</p>
				<ul class="feature-list">
