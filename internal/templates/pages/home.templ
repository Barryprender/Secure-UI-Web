package pages

import (
	"secure-ui-showcase-go/internal/middleware"
	"secure-ui-showcase-go/internal/templates"
)

templ Home() {
	@templates.Layout("Security-First Web Components", "Zero-dependency web components with built-in XSS protection, rate limiting, CSRF defence, and CSP-safe Shadow DOM. Security-first, works with any framework.") {
		@templates.HomeJsonLDScript()
		<!-- Hero Section -->
<section class="hero-section">
	<div class="container">
		<div class="hero-content">
			<div class="hero-badge">
				<span class="badge badge-primary">Zero Dependencies</span>
			</div>

			<h1 class="hero-title">
				Build Secure Web Apps<br />
				Without Compromise
			</h1>

			<p class="hero-description">
				A security-first web component library with built-in protection against XSS, CSRF,
				and common web vulnerabilities. Zero dependencies, progressive enhancement, graceful degradation without JavaScript.
			</p>

			<div class="hero-cta">
				<a href="/documentation" class="btn btn-primary">Get Started</a>
				<a href="/forms" class="btn btn-secondary">View Examples</a>
			</div>
		</div>
	</div>
</section>

<!-- Stats Section -->
<section class="stats-section">
	<div class="container">
		<div class="stats-grid">
			<div class="stat-card">
				<div class="stat-value">Zero</div>
				<div class="stat-label">Dependencies</div>
			</div>

			<div class="stat-card">
				<div class="stat-value">Server</div>
				<div class="stat-label">Authoritative</div>
			</div>

			<div class="stat-card">
				<div class="stat-value">Built-in</div>
				<div class="stat-label">Security</div>
			</div>
		</div>
	</div>
</section>

<!-- Built-in Security Features Section -->
<section class="features-section">
	<div class="container">
		<div class="section-header">
			<h2 class="section-title">Built-In Security Features</h2>
			<p class="section-description">
				Comprehensive security protection enabled by default. Secure out of the box with sensible defaults.
			</p>
		</div>

		<div class="features-grid">
			<!-- CSRF Protection -->
			<div class="feature-card">
				<div class="feature-icon">
					<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
						<path d="m9 12 2 2 4-4"></path>
					</svg>
				</div>
				<h3 class="feature-title">Automatic CSRF Protection</h3>
				<p class="feature-description">
					All forms automatically include CSRF tokens. No manual token management required.
				</p>
				<ul class="feature-list">
					<li>Per-request token generation</li>
					<li>Automatic token validation</li>
					<li>Seamless integration</li>
				</ul>
			</div>

			<!-- Server-Side Validation -->
			<div class="feature-card">
				<div class="feature-icon">
					<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<rect x="2" y="2" width="20" height="8" rx="2" ry="2"></rect>
						<rect x="2" y="14" width="20" height="8" rx="2" ry="2"></rect>
						<line x1="6" y1="6" x2="6.01" y2="6"></line>
						<line x1="6" y1="18" x2="6.01" y2="18"></line>
						<path d="m15 11 2 2 4-4"></path>
					</svg>
				</div>
				<h3 class="feature-title">Layered Validation</h3>
				<p class="feature-description">
					Client-side validation for instant feedback, server-side validation as the security boundary. Defence in depth.
				</p>
				<ul class="feature-list">
					<li>Real-time client-side feedback</li>
					<li>Server-authoritative validation</li>
					<li>Detailed error messages</li>
				</ul>
			</div>

			<!-- Input Sanitization -->
			<div class="feature-card">
				<div class="feature-icon">
					<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<polyline points="16 18 22 12 16 6"></polyline>
						<polyline points="8 6 2 12 8 18"></polyline>
						<line x1="15" y1="4" x2="9" y2="20"></line>
					</svg>
				</div>
				<h3 class="feature-title">Input Sanitization</h3>
				<p class="feature-description">
					Automatic sanitization of all user input. XSS prevention built into every component.
				</p>
				<ul class="feature-list">
					<li>HTML entity encoding</li>
					<li>Script tag stripping</li>
					<li>Event handler removal</li>
				</ul>
			</div>

			<!-- Secure Defaults -->
			<div class="feature-card">
				<div class="feature-icon">
					<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
						<path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
					</svg>
				</div>
				<h3 class="feature-title">Secure Defaults</h3>
				<p class="feature-description">
					Security-first configuration out of the box. Strict CSP, secure headers, and safe cookies.
				</p>
				<ul class="feature-list">
					<li>Strict Content Security Policy</li>
					<li>Closed Shadow DOM isolation</li>
					<li>Tier-based security controls</li>
				</ul>
			</div>

			<!-- Single Source of Truth -->
			<div class="feature-card">
				<div class="feature-icon">
					<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<ellipse cx="12" cy="5" rx="9" ry="3"></ellipse>
						<path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"></path>
						<path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"></path>
					</svg>
				</div>
				<h3 class="feature-title">Single Source of Truth</h3>
				<p class="feature-description">
					Server owns all persistent state and security decisions. Components manage only transient UI state.
				</p>
				<ul class="feature-list">
					<li>Server-authoritative data</li>
					<li>No client-server state sync</li>
					<li>Consistent security enforcement</li>
				</ul>
			</div>

			<!-- Audit-Ready Logging -->
			<div class="feature-card">
				<div class="feature-icon">
					<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"></path>
						<rect x="8" y="2" width="8" height="4" rx="1" ry="1"></rect>
						<line x1="8" y1="10" x2="16" y2="10"></line>
						<line x1="8" y1="14" x2="16" y2="14"></line>
						<line x1="8" y1="18" x2="12" y2="18"></line>
					</svg>
				</div>
				<h3 class="feature-title">Audit-Ready Logging</h3>
				<p class="feature-description">
					Client-side security event logging built into every component for compliance and monitoring.
				</p>
				<ul class="feature-list">
					<li>Component interaction events</li>
					<li>Security tier violations</li>
					<li>Input validation errors</li>
				</ul>
			</div>
		</div>
	</div>
</section>

<!-- OWASP Top 10:2021 Alignment Section -->
<section class="owasp-section">
	<div class="container">
		<div class="section-header">
			<h2 class="section-title">OWASP Top 10:2021 Alignment</h2>
			<p class="section-description">
				Secure-UI components address key risks from the
				<a href="https://owasp.org/www-project-top-ten/" target="_blank" rel="noopener" class="owasp-link">OWASP Top 10:2021</a>,
				providing client-side defences that complement your server-side security.
			</p>
		</div>

		<div class="owasp-grid">
			<div class="owasp-card owasp-card--covered">
				<div class="owasp-card-header">
					<span class="owasp-id">A01</span>
					<span class="owasp-coverage owasp-coverage--direct">Addressed</span>
				</div>
				<h3 class="owasp-card-title">Broken Access Control</h3>
				<p class="owasp-card-text">
					Automatic CSRF token injection and validation via <code>&lt;secure-form&gt;</code>.
					Immutable security tiers prevent runtime downgrade.
				</p>
			</div>

			<div class="owasp-card owasp-card--partial">
				<div class="owasp-card-header">
					<span class="owasp-id">A02</span>
					<span class="owasp-coverage owasp-coverage--partial">Complementary</span>
				</div>
				<h3 class="owasp-card-title">Cryptographic Failures</h3>
				<p class="owasp-card-text">
					Disables autocomplete and browser caching for sensitive and critical tiers.
					Cryptographic controls (TLS, hashing) require server-side implementation.
				</p>
			</div>

			<div class="owasp-card owasp-card--covered">
				<div class="owasp-card-header">
					<span class="owasp-id">A03</span>
					<span class="owasp-coverage owasp-coverage--direct">Addressed</span>
				</div>
				<h3 class="owasp-card-title">Injection</h3>
				<p class="owasp-card-text">
					All input is sanitized via HTML entity encoding, script tag stripping,
					and event handler removal. Closed Shadow DOM isolates component internals.
				</p>
			</div>

			<div class="owasp-card owasp-card--covered">
				<div class="owasp-card-header">
					<span class="owasp-id">A04</span>
					<span class="owasp-coverage owasp-coverage--direct">Addressed</span>
				</div>
				<h3 class="owasp-card-title">Insecure Design</h3>
				<p class="owasp-card-text">
					Security-by-default architecture. Fail-secure defaults, four-tier security model,
					and progressive enhancement ensure security without developer effort.
				</p>
			</div>

			<div class="owasp-card owasp-card--covered">
				<div class="owasp-card-header">
					<span class="owasp-id">A05</span>
					<span class="owasp-coverage owasp-coverage--direct">Addressed</span>
				</div>
				<h3 class="owasp-card-title">Security Misconfiguration</h3>
				<p class="owasp-card-text">
					Defaults to CRITICAL tier (highest security). Provides CSP directives and
					security header recommendations out of the box.
				</p>
			</div>

			<div class="owasp-card owasp-card--covered">
				<div class="owasp-card-header">
					<span class="owasp-id">A06</span>
					<span class="owasp-coverage owasp-coverage--direct">Addressed</span>
				</div>
				<h3 class="owasp-card-title">Vulnerable and Outdated Components</h3>
				<p class="owasp-card-text">
					Zero runtime dependencies. No transitive supply chain risk.
					The entire library is self-contained TypeScript.
				</p>
			</div>

			<div class="owasp-card owasp-card--partial">
				<div class="owasp-card-header">
					<span class="owasp-id">A07</span>
					<span class="owasp-coverage owasp-coverage--partial">Complementary</span>
				</div>
				<h3 class="owasp-card-title">Identification and Authentication Failures</h3>
				<p class="owasp-card-text">
					Client-side rate limiting on sensitive and critical tiers throttles brute-force attempts.
					Authentication logic requires server-side implementation.
				</p>
			</div>

			<div class="owasp-card owasp-card--covered">
				<div class="owasp-card-header">
					<span class="owasp-id">A08</span>
					<span class="owasp-coverage owasp-coverage--direct">Addressed</span>
				</div>
				<h3 class="owasp-card-title">Software and Data Integrity Failures</h3>
				<p class="owasp-card-text">
					CSRF protection prevents cross-site request forgery. File upload scan hooks
					validate file integrity. Closed Shadow DOM prevents DOM tampering.
				</p>
			</div>

			<div class="owasp-card owasp-card--covered">
				<div class="owasp-card-header">
					<span class="owasp-id">A09</span>
					<span class="owasp-coverage owasp-coverage--direct">Addressed</span>
				</div>
				<h3 class="owasp-card-title">Security Logging and Monitoring Failures</h3>
				<p class="owasp-card-text">
					Every component records client-side security events via <code>getAuditLog()</code> and
					<code>secure-audit</code> custom events. Tier-configurable logging detail.
				</p>
			</div>

			<div class="owasp-card owasp-card--partial">
				<div class="owasp-card-header">
					<span class="owasp-id">A10</span>
					<span class="owasp-coverage owasp-coverage--partial">Complementary</span>
				</div>
				<h3 class="owasp-card-title">Server-Side Request Forgery (SSRF)</h3>
				<p class="owasp-card-text">
					CSP <code>form-action 'self'</code> restricts form submissions to the same origin.
					Components make no outbound requests. Server-side URL validation remains required.
				</p>
			</div>
		</div>

		<div class="owasp-disclaimer">
			<p>
				Secure-UI provides client-side defences as part of a defence-in-depth strategy.
				Server-side validation, authentication, and encryption remain essential.
			</p>
		</div>
	</div>
</section>

<!-- Security Without Complexity Section -->
<section class="code-section">
	<div class="container">
		<div class="section-header">
			<h2 class="section-title">Security Without Complexity</h2>
			<p class="section-description">
				Simple code that's automatically secure. No complex security configurations needed.
			</p>
		</div>

		<div class="code-comparison">
			<div class="code-example">
				<div class="code-header">
					<span class="code-title">Secure Form Handler</span>
					<span class="badge badge-primary">Built-in Protection</span>
				</div>
				<div class="code-content">
					<pre><code class="language-go">{ `// CSRF validation handled by middleware
func HandleForm(w http.ResponseWriter, r *http.Request) {
    if err := r.ParseForm(); err != nil {
        http.Error(w, "Bad Request", 400)
        return
    }

    // Sanitize and validate server-side
    email := validation.Sanitize(r.FormValue("email"))

    v := validation.New()
    v.Required("email", email, "Email").
        Email("email", email, "Email")

    if !v.Result().IsValid() {
        renderError(w, v.Result().Errors)
        return
    }
}` }</code></pre>
				</div>
			</div>
		</div>
	</div>
</section>

<!-- Complete Theming Control Section -->
<section class="theming-section">
	<div class="container">
		<div class="section-header">
			<h2 class="section-title">Complete Theming Control</h2>
			<p class="section-description">
				CSS custom properties as design tokens. Override globally, per component, or per instance. Five built-in presets — or build your own.
			</p>
		</div>

		<div class="home-theme-showcase">
			<div class="home-theme-tabs" role="tablist" aria-label="Theme presets">
				<button class="home-theme-tab" data-theme="default" role="tab" aria-selected="true">
					<span class="home-theme-tab-dot"></span>
					Default
				</button>
				<button class="home-theme-tab" data-theme="dark" role="tab" aria-selected="false">
					<span class="home-theme-tab-dot"></span>
					Dark
				</button>
				<button class="home-theme-tab" data-theme="ocean" role="tab" aria-selected="false">
					<span class="home-theme-tab-dot"></span>
					Ocean
				</button>
				<button class="home-theme-tab" data-theme="forest" role="tab" aria-selected="false">
					<span class="home-theme-tab-dot"></span>
					Forest
				</button>
				<button class="home-theme-tab" data-theme="enterprise" role="tab" aria-selected="false">
					<span class="home-theme-tab-dot"></span>
					Enterprise
				</button>
			</div>

			<div class="home-theme-preview" id="home-theme-preview" aria-live="polite">
				<div class="home-theme-preview-left">
					<div class="home-theme-preview-card">
						<div class="home-theme-preview-card-header">
							<span class="home-theme-preview-logo">Secure-UI</span>
							<span class="home-theme-preview-badge">v2.0</span>
						</div>
						<div class="home-theme-preview-field">
							<div class="home-theme-preview-label">Email address</div>
							<div class="home-theme-preview-input">
								<span>alice@example.com</span>
								<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>
							</div>
						</div>
						<div class="home-theme-preview-field">
							<div class="home-theme-preview-label">Security tier</div>
							<div class="home-theme-preview-input home-theme-preview-input--select">
								<span>Sensitive</span>
							</div>
						</div>
						<button class="home-theme-preview-btn">Submit Securely</button>
					</div>
				</div>
				<div class="home-theme-preview-right">
					<div class="home-theme-preview-tokens">
						<div class="home-theme-token-row">
							<span class="home-theme-token-label">--accent-primary</span>
							<span class="home-theme-token-swatch home-theme-swatch-accent"></span>
						</div>
						<div class="home-theme-token-row">
							<span class="home-theme-token-label">--bg-primary</span>
							<span class="home-theme-token-swatch home-theme-swatch-bg"></span>
						</div>
						<div class="home-theme-token-row">
							<span class="home-theme-token-label">--text-primary</span>
							<span class="home-theme-token-swatch home-theme-swatch-text"></span>
						</div>
					</div>
					<div class="home-theme-preview-code">
						<div class="home-theme-preview-code-title">Theme override</div>
						<pre class="home-theme-preview-code-block" id="home-theme-code-display">/* Default theme */</pre>
					</div>
				</div>
			</div>
		</div>

		<div class="home-theming-cta">
			<a href="/theming" class="btn btn-secondary">Explore full theming guide &#8594;</a>
		</div>
	</div>
</section>

<script type="module" nonce={ middleware.NonceFromContext(ctx) }>
const themes = {
  default: {
    '--accent-primary': '#10b981', '--accent-secondary': '#059669',
    '--accent-glow': 'rgba(16,185,129,0.15)', '--bg-primary': '#ffffff',
    '--bg-secondary': '#f8f9fa', '--bg-elevated': '#ffffff',
    '--text-primary': '#1a1a2e', '--text-secondary': '#4a5568',
    '--border-subtle': '#e2e8f0', '--border-medium': '#cbd5e1',
    label: '/* Default theme — no overrides needed */',
  },
  dark: {
    '--accent-primary': '#6366f1', '--accent-secondary': '#4f46e5',
    '--accent-glow': 'rgba(99,102,241,0.2)', '--bg-primary': '#0a0a0f',
    '--bg-secondary': '#121218', '--bg-elevated': '#1c1c28',
    '--text-primary': '#f0f4ff', '--text-secondary': '#94a3b8',
    '--border-subtle': 'rgba(255,255,255,0.08)', '--border-medium': 'rgba(255,255,255,0.12)',
    label: ':root {\n  --accent-primary: #6366f1;\n  --bg-primary: #0a0a0f;\n  --text-primary: #f0f4ff;\n}',
  },
  ocean: {
    '--accent-primary': '#0284c7', '--accent-secondary': '#0369a1',
    '--accent-glow': 'rgba(2,132,199,0.15)', '--bg-primary': '#f0f9ff',
    '--bg-secondary': '#e0f2fe', '--bg-elevated': '#ffffff',
    '--text-primary': '#0c4a6e', '--text-secondary': '#0369a1',
    '--border-subtle': '#bae6fd', '--border-medium': '#7dd3fc',
    label: ':root {\n  --accent-primary: #0284c7;\n  --bg-primary: #f0f9ff;\n  --text-primary: #0c4a6e;\n}',
  },
  forest: {
    '--accent-primary': '#16a34a', '--accent-secondary': '#15803d',
    '--accent-glow': 'rgba(22,163,74,0.15)', '--bg-primary': '#f0fdf4',
    '--bg-secondary': '#dcfce7', '--bg-elevated': '#ffffff',
    '--text-primary': '#14532d', '--text-secondary': '#166534',
    '--border-subtle': '#bbf7d0', '--border-medium': '#86efac',
    label: ':root {\n  --accent-primary: #16a34a;\n  --bg-primary: #f0fdf4;\n  --text-primary: #14532d;\n}',
  },
  enterprise: {
    '--accent-primary': '#2563eb', '--accent-secondary': '#1d4ed8',
    '--accent-glow': 'rgba(37,99,235,0.12)', '--bg-primary': '#ffffff',
    '--bg-secondary': '#f8fafc', '--bg-elevated': '#ffffff',
    '--text-primary': '#0f172a', '--text-secondary': '#475569',
    '--border-subtle': '#e2e8f0', '--border-medium': '#cbd5e1',
    label: ':root {\n  --accent-primary: #2563eb;\n  --text-primary: #0f172a;\n}',
  },
};

const preview = document.getElementById('home-theme-preview');
const codeDisplay = document.getElementById('home-theme-code-display');
const tabs = document.querySelectorAll('.home-theme-tab');

function applyTheme(name) {
  const t = themes[name];
  if (!t || !preview) return;
  for (const [key, val] of Object.entries(t)) {
    if (key.startsWith('--')) preview.style.setProperty(key, val);
  }
  if (codeDisplay) codeDisplay.textContent = t.label;
}

tabs.forEach(tab => {
  tab.addEventListener('click', () => {
    tabs.forEach(t => { t.classList.remove('home-theme-tab--active'); t.setAttribute('aria-selected', 'false'); });
    tab.classList.add('home-theme-tab--active');
    tab.setAttribute('aria-selected', 'true');
    applyTheme(tab.dataset.theme ?? 'default');
  });
});

if (tabs.length > 0) {
  tabs[0].classList.add('home-theme-tab--active');
  applyTheme('default');
}
</script>

<!-- Progressive Enhancement Section -->
<section class="no-js-section">
	<div class="container">
		<div class="section-header">
			<h2 class="section-title">Progressive Enhancement</h2>
			<p class="section-description">
				Built on semantic HTML foundations. Full functionality with JavaScript, graceful fallback without it.
			</p>
		</div>

		<div class="no-js-grid">
			<div class="no-js-card">
				<div class="no-js-icon">
