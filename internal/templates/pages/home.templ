		<!-- Code comparison -->
		<div class="code-comparison swc-code-comparison">
			<div class="code-example">
				<div class="code-header">
					<span class="code-title">Component markup</span>
					<span class="badge badge-primary">Any framework</span>
				</div>
				<div class="code-content">
					<pre><code class="language-markup">{ `<!-- Works identically in React, Vue,
     Angular, Svelte, or Go templates -->

<secure-form action="/register" method="POST">

  <secure-input
    name="email"
    type="email"
    label="Email address"
    security-tier="sensitive"
    required>
  </secure-input>

  <secure-input
    name="password"
    type="password"
    label="Password"
    security-tier="critical"
    required>
  </secure-input>

  <secure-submit-button>
    Create account
  </secure-submit-button>

</secure-form>

<!-- CSRF token injected automatically.
     XSS prevention active on every field.
     Audit log available via getAuditLog(). -->` }</code></pre>
				</div>
			</div>
			<div class="code-example">
				<div class="code-header">
					<span class="code-title">Server handler</span>
					<span class="badge badge-primary">Go example</span>
				</div>
				<div class="code-content">
					<pre><code class="language-go">{ `// CSRF already validated by middleware.
// No manual token handling required.
func (h *Handlers) Register(
    w http.ResponseWriter,
    r *http.Request,
) {
    email := validation.Sanitize(
        r.FormValue("email"),
    )
    password := r.FormValue("password")

    v := validation.New()
    v.Required("email", email, "Email").
        Email("email", email, "Email").
        Required("password", password, "Password").
        MinLength("password", password, 8, "Password")

    if !v.Result().IsValid() {
        // Re-render form with errors.
        // Component preserves field values.
        renderWithErrors(w, r, v.Result())
        return
    }

    // Components sanitized client-side too,
    // but server-side is the security boundary.
    h.auth.Register(r.Context(), email, password)
}` }</code></pre>
				</div>
			</div>
		</div>

