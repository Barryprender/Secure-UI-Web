<!-- OWASP Top 10:2021 Alignment Section -->
<section class="owasp-section" id="owasp">
	<div class="container">
		<div class="section-header">
			<p class="section-eyebrow">{ i18n.T(ctx, "home.owasp.eyebrow") }</p>
			<h2 class="section-title">{ i18n.T(ctx, "home.owasp.title") }</h2>
			<p class="section-description">
				{ i18n.T(ctx, "home.owasp.desc") }
				<a href="https://owasp.org/www-project-top-ten/" target="_blank" rel="noopener" class="owasp-link">OWASP Top 10:2021</a>.
			</p>
		</div>

		<div class="owasp-table-wrapper" data-reveal-rows>
			<table class="owasp-table">
				<thead>
					<tr>
						<th>Risk</th>
						<th>Title</th>
						<th>Coverage</th>
						<th>How Secure-UI helps</th>
					</tr>
				</thead>
				<tbody>
					<tr class="owasp-row--addressed">
						<td class="owasp-table-id">A01</td>
						<td class="owasp-table-title">Broken Access Control</td>
						<td><span class="owasp-coverage-badge owasp-coverage-badge--direct">Addressed</span></td>
						<td class="owasp-table-how">Automatic CSRF token injection via <a href="/documentation/secure-form"><code>&lt;secure-form&gt;</code></a>. Immutable security tiers prevent runtime downgrade.</td>
					</tr>
					<tr class="owasp-row--complementary">
						<td class="owasp-table-id">A02</td>
						<td class="owasp-table-title">Cryptographic Failures</td>
						<td><span class="owasp-coverage-badge owasp-coverage-badge--partial">Complementary</span></td>
						<td class="owasp-table-how">Disables autocomplete and browser caching on sensitive and critical tiers via <a href="/documentation/secure-input"><code>&lt;secure-input&gt;</code></a>. Cryptographic controls require server-side implementation.</td>
					</tr>
					<tr class="owasp-row--addressed">
						<td class="owasp-table-id">A03</td>
						<td class="owasp-table-title">Injection</td>
						<td><span class="owasp-coverage-badge owasp-coverage-badge--direct">Addressed</span></td>
						<td class="owasp-table-how">All input sanitized via HTML entity encoding, script tag stripping, and event handler removal. Closed Shadow DOM isolates component internals. See <a href="/documentation/secure-input">secure-input</a> and <a href="/documentation/secure-textarea">secure-textarea</a>.</td>
					</tr>
					<tr class="owasp-row--addressed">
						<td class="owasp-table-id">A04</td>
						<td class="owasp-table-title">Insecure Design</td>
						<td><span class="owasp-coverage-badge owasp-coverage-badge--direct">Addressed</span></td>
						<td class="owasp-table-how">Security-by-default architecture. Fail-secure defaults, four-tier security model, and progressive enhancement ensure security without developer effort. See <a href="/documentation">all components</a>.</td>
					</tr>
					<tr class="owasp-row--addressed">
						<td class="owasp-table-id">A05</td>
						<td class="owasp-table-title">Security Misconfiguration</td>
						<td><span class="owasp-coverage-badge owasp-coverage-badge--direct">Addressed</span></td>
						<td class="owasp-table-how">Defaults to CRITICAL tier. Provides CSP directives and security header recommendations out of the box. See <a href="/documentation/secure-form">secure-form</a>.</td>
					</tr>
					<tr class="owasp-row--addressed">
						<td class="owasp-table-id">A06</td>
						<td class="owasp-table-title">Vulnerable and Outdated Components</td>
						<td><span class="owasp-coverage-badge owasp-coverage-badge--direct">Addressed</span></td>
						<td class="owasp-table-how">Zero runtime dependencies. No transitive supply chain risk. The entire library is self-contained TypeScript. See <a href="/documentation/secure-file-upload">secure-file-upload</a>; upload integrity hooks included.</td>
					</tr>
					<tr class="owasp-row--complementary">
						<td class="owasp-table-id">A07</td>
						<td class="owasp-table-title">Authentication Failures</td>
						<td><span class="owasp-coverage-badge owasp-coverage-badge--partial">Complementary</span></td>
						<td class="owasp-table-how">Behavioral telemetry via <a href="/documentation/secure-telemetry-provider">secure-telemetry-provider</a> detects automated clients before submission. Client-side rate limiting on sensitive and critical tiers adds a secondary layer. Authentication logic requires server-side implementation.</td>
					</tr>
					<tr class="owasp-row--addressed">
						<td class="owasp-table-id">A08</td>
						<td class="owasp-table-title">Software and Data Integrity Failures</td>
						<td><span class="owasp-coverage-badge owasp-coverage-badge--direct">Addressed</span></td>
						<td class="owasp-table-how">CSRF protection via <a href="/documentation/secure-form">secure-form</a>. File upload scan hooks via <a href="/documentation/secure-file-upload">secure-file-upload</a>. Closed Shadow DOM prevents DOM tampering.</td>
					</tr>
					<tr class="owasp-row--addressed">
						<td class="owasp-table-id">A09</td>
						<td class="owasp-table-title">Security Logging Failures</td>
						<td><span class="owasp-coverage-badge owasp-coverage-badge--direct">Addressed</span></td>
						<td class="owasp-table-how">Every component records client-side security events via <code>getAuditLog()</code> and <code>secure-audit</code> events. See <a href="/documentation/secure-telemetry-provider">secure-telemetry-provider</a>.</td>
					</tr>
					<tr class="owasp-row--complementary">
						<td class="owasp-table-id">A10</td>
						<td class="owasp-table-title">Server-Side Request Forgery</td>
						<td><span class="owasp-coverage-badge owasp-coverage-badge--partial">Complementary</span></td>
						<td class="owasp-table-how">CSP <code>form-action 'self'</code> restricts form submissions to the same origin via <a href="/documentation/secure-form">secure-form</a>. Components make no outbound requests.</td>
					</tr>
				</tbody>
			</table>
		</div>

		<p class="owasp-disclaimer">{ i18n.T(ctx, "home.owasp.disclaimer") }</p>
	</div>
</section>

