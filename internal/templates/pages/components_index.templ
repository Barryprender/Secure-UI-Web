				<!-- secure-file-upload -->
				<a href="/components/secure-file-upload" class="component-card" data-ci-index="5">
					<div class="card-preview card-preview--upload" aria-hidden="true">
						<div class="cp-upload-filename">
							<span class="cp-upload-arrow">&#8593;</span>
							report.pdf
						</div>
						<div class="cp-progress-track">
							<div class="cp-progress-fill"></div>
						</div>
						<div class="cp-upload-meta">MIME &middot; SIZE &middot; MAGIC</div>
					</div>
					<span class="component-card-tag">&lt;secure-file-upload&gt;</span>
					<p class="component-card-desc">{ i18n.T(ctx, "ci.card.upload.desc") }</p>
					<ul class="component-card-features">
						<li>MIME type validation</li>
						<li>Magic number verification</li>
						<li>Scan hook integration</li>
					</ul>
				</a>

				<!-- secure-datetime -->
				<a href="/components/secure-datetime" class="component-card" data-ci-index="6">
					<div class="card-preview card-preview--datetime" aria-hidden="true">
						<div class="cp-dt-header">March 2026</div>
						<div class="cp-dt-grid">
							<span class="cp-dt-cell">3</span>
							<span class="cp-dt-cell">10</span>
							<span class="cp-dt-cell">17</span>
							<span class="cp-dt-cell">24</span>
							<span class="cp-dt-cell">4</span>
							<span class="cp-dt-cell">11</span>
							<span class="cp-dt-cell cp-dt-cell--pulse">18</span>
							<span class="cp-dt-cell">25</span>
						</div>
					</div>
					<span class="component-card-tag">&lt;secure-datetime&gt;</span>
					<p class="component-card-desc">{ i18n.T(ctx, "ci.card.datetime.desc") }</p>
					<ul class="component-card-features">
						<li>Range enforcement (min/max)</li>
						<li>Timezone normalization</li>
						<li>All date/time subtypes</li>
					</ul>
				</a>

				<!-- secure-table -->
				<a href="/components/secure-table" class="component-card" data-ci-index="7">
					<div class="card-preview card-preview--table" aria-hidden="true">
						<div class="cp-tbl-head">
							<span>Name</span><span>Role</span><span>&#9679;</span>
						</div>
						<div class="cp-tbl-row cp-tbl-row--1">
							<span>Alice</span><span>Admin</span><span class="cp-dot cp-dot--green"></span>
						</div>
						<div class="cp-tbl-row cp-tbl-row--2">
							<span>Bob</span><span>User</span><span class="cp-dot cp-dot--green"></span>
						</div>
						<div class="cp-tbl-row cp-tbl-row--3">
							<span>Carol</span><span>Editor</span><span class="cp-dot cp-dot--amber"></span>
						</div>
					</div>
					<span class="component-card-tag">&lt;secure-table&gt;</span>
					<p class="component-card-desc">{ i18n.T(ctx, "ci.card.table.desc") }</p>
					<ul class="component-card-features">
						<li>XSS-safe data rendering</li>
						<li>Sortable and filterable</li>
						<li>Pagination support</li>
					</ul>
				</a>

				<!-- secure-password-confirm -->
				<a href="/components/secure-password-confirm" class="component-card" data-ci-index="8">
					<div class="card-preview card-preview--password-confirm" aria-hidden="true">
						<div class="cp-pw-field">
							<div class="cp-pw-label">New Password</div>
							<div class="cp-pw-input"><span class="cp-pw-dots">&#9679;&#9679;&#9679;&#9679;&#9679;&#9679;&#9679;&#9679;</span><span class="cp-pw-eye">&#128065;</span></div>
						</div>
						<div class="cp-pw-field">
							<div class="cp-pw-label">Confirm Password</div>
							<div class="cp-pw-input cp-pw-input--match"><span class="cp-pw-dots">&#9679;&#9679;&#9679;&#9679;&#9679;&#9679;&#9679;&#9679;</span><span class="cp-pw-eye">&#128065;</span></div>
						</div>
						<div class="cp-pw-match">&#10003; Passwords match</div>
					</div>
					<span class="component-card-tag">&lt;secure-password-confirm&gt;</span>
					<p class="component-card-desc">Linked new-password and confirm-password fields with match validation, strength enforcement, and animated show/hide toggle.</p>
					<ul class="component-card-features">
						<li>Match validation on blur</li>
						<li>Strength rules enforced</li>
						<li>Raw value never in events</li>
					</ul>
				</a>

				<!-- secure-card -->
				<a href="/components/secure-card" class="component-card" data-ci-index="9">
					<div class="card-preview card-preview--payment" aria-hidden="true">
						<div class="cp-payment-scene">
							<div class="cp-payment-front">
								<div class="cp-payment-chip"></div>
								<div class="cp-payment-number">&#8226;&#8226;&#8226;&#8226; &#8226;&#8226;&#8226;&#8226; &#8226;&#8226;&#8226;&#8226; 4242</div>
								<div class="cp-payment-name">ALICE JOHNSON</div>
							</div>
							<div class="cp-payment-back">
								<div class="cp-payment-stripe"></div>
								<div class="cp-payment-cvv"><span>CVV</span> &#8226;&#8226;&#8226;</div>
							</div>
						</div>
					</div>
					<span class="component-card-tag">&lt;secure-card&gt;</span>
					<p class="component-card-desc">{ i18n.T(ctx, "ci.card.payment.desc") }</p>
					<ul class="component-card-features">
						<li>Full PAN never exposed</li>
						<li>Luhn + card type validation</li>
						<li>Animated 3D card preview</li>
					</ul>
				</a>

			</div>

			<!-- Framework section -->
			<section class="ci-framework">
				<div class="ci-framework-inner">
					<h2 class="ci-framework-title">{ i18n.T(ctx, "ci.fw.title") }</h2>
					<p class="ci-framework-desc">{ i18n.T(ctx, "ci.fw.desc") }</p>
					<div class="ci-framework-tags">
						<span class="ci-fw-tag">HTML</span>
						<span class="ci-fw-tag">React</span>
						<span class="ci-fw-tag">Vue</span>
						<span class="ci-fw-tag">Angular</span>
						<span class="ci-fw-tag">Svelte</span>
						<span class="ci-fw-tag ci-fw-tag--accent">Go Templ</span>
					</div>
				</div>
			</section>

			<script type="module" nonce={ middleware.NonceFromContext(ctx) }>
const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

// Counter animation (9 components, 4 tiers)
if (!reduceMotion) {
  document.querySelectorAll('.ci-stat-num[data-target]').forEach(el => {
    const target = parseInt(el.dataset.target, 10);
    if (target === 0) return;
    el.textContent = '0';
    const duration = 900;
    const start = performance.now();
    const easeOut = t => 1 - Math.pow(1 - t, 3);
    const tick = now => {
      const p = Math.min((now - start) / duration, 1);
      el.textContent = Math.round(easeOut(p) * target);
      if (p < 1) requestAnimationFrame(tick);
      else el.textContent = target;
    };
    setTimeout(() => requestAnimationFrame(tick), 300);
  });
}

// Card entrance stagger via IntersectionObserver
const grid = document.getElementById('ci-grid');
if (grid) {
  if (reduceMotion) {
    grid.querySelectorAll('.component-card').forEach(c => c.classList.add('ci-card-visible'));
  } else {
    const obs = new IntersectionObserver(entries => {
      entries.forEach(entry => {
        if (!entry.isIntersecting) return;
        const idx = parseInt(entry.target.dataset.ciIndex ?? '0', 10);
        setTimeout(() => entry.target.classList.add('ci-card-visible'), idx * 60);
        obs.unobserve(entry.target);
      });
    }, { threshold: 0.06, rootMargin: '0px 0px -32px 0px' });
    grid.querySelectorAll('.component-card').forEach(c => obs.observe(c));
  }
}
			</script>
		</div>
	}
}
